{
  "_meta": {
    "title": "MSSQL → MySQL 문자열 함수 변환",
    "category": "FUNCTION_STRING",
    "src_db": "mssql",
    "tgt_db": "mysql",
    "version": "1.0",
    "description": "모든 문자열 처리 함수 변환 — 인자 순서 및 인덱스 차이 주의"
  },
  "rules": [
    {
      "id": "fn_str_len",
      "src": "LEN(str)",
      "tgt": "CHAR_LENGTH(str)",
      "note": "문자 수 반환. LEN은 후행 공백 무시, CHAR_LENGTH는 포함. LENGTH()는 바이트 수",
      "warning": true,
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_datalength",
      "src": "DATALENGTH(str)",
      "tgt": "LENGTH(str)",
      "note": "바이트 길이. 유니코드는 MSSQL 2배 vs MySQL utf8mb4 최대 4배",
      "warning": true,
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_substring",
      "src": "SUBSTRING(str, start, length)",
      "tgt": "SUBSTRING(str, start, length)",
      "note": "SUBSTRING OK — 1부터 시작하는 인덱스 동일",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_charindex",
      "src": "CHARINDEX(search, str)",
      "tgt": "LOCATE(search, str)",
      "note": "⚠ CHARINDEX(찾을값, 대상문자열) → LOCATE(찾을값, 대상문자열). 인자 순서 동일",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_charindex_start",
      "src": "CHARINDEX(search, str, start_pos)",
      "tgt": "LOCATE(search, str, start_pos)",
      "note": "시작 위치 지정 검색",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_instr",
      "src": "INSTR(str, search)",
      "tgt": "LOCATE(search, str)",
      "note": "⚠ INSTR(대상, 찾을값) → LOCATE(찾을값, 대상). 인자 순서 반대!",
      "warning": true,
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_left",
      "src": "LEFT(str, n)",
      "tgt": "LEFT(str, n)",
      "note": "LEFT() OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_right",
      "src": "RIGHT(str, n)",
      "tgt": "RIGHT(str, n)",
      "note": "RIGHT() OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_ltrim",
      "src": "LTRIM(str)",
      "tgt": "LTRIM(str)",
      "note": "왼쪽 공백 제거 OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_rtrim",
      "src": "RTRIM(str)",
      "tgt": "RTRIM(str)",
      "note": "오른쪽 공백 제거 OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_trim_both",
      "src": "LTRIM(RTRIM(str))",
      "tgt": "TRIM(str)",
      "note": "양쪽 공백 제거 → TRIM(). MySQL 8.0+ TRIM() 지원",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_upper",
      "src": "UPPER(str)",
      "tgt": "UPPER(str)",
      "note": "대문자 변환 OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_lower",
      "src": "LOWER(str)",
      "tgt": "LOWER(str)",
      "note": "소문자 변환 OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_replace",
      "src": "REPLACE(str, old, new)",
      "tgt": "REPLACE(str, old, new)",
      "note": "REPLACE OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_reverse",
      "src": "REVERSE(str)",
      "tgt": "REVERSE(str)",
      "note": "REVERSE OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_replicate",
      "src": "REPLICATE(str, n)",
      "tgt": "REPEAT(str, n)",
      "note": "문자열 반복 — REPLICATE → REPEAT",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_space",
      "src": "SPACE(n)",
      "tgt": "SPACE(n)",
      "note": "공백 n개 생성 OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_str_num",
      "src": "STR(num, length, decimal)",
      "tgt": "FORMAT(num, decimal)",
      "note": "숫자→문자열. FORMAT은 천단위 구분자 포함. CAST/CONVERT 고려",
      "warning": true,
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_stuff",
      "src": "STUFF(str, start, length, new_str)",
      "tgt": "INSERT(str, start, length, new_str)",
      "note": "문자열 삽입/교체 — STUFF → INSERT (MySQL INSERT는 문자열 함수)",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_soundex",
      "src": "SOUNDEX(str)",
      "tgt": "SOUNDEX(str)",
      "note": "SOUNDEX OK (발음 유사도)",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_difference",
      "src": "DIFFERENCE(str1, str2)",
      "tgt": "-- MySQL 미지원. 직접 구현 필요",
      "note": "SOUNDEX 유사도 비교 — MySQL 미지원",
      "warning": true,
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_patindex",
      "src": "PATINDEX('%pattern%', str)",
      "tgt": "LOCATE('pattern', str)",
      "note": "패턴 위치 검색 — 와일드카드 패턴이면 REGEXP_INSTR() 사용",
      "warning": true,
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_concat",
      "src": "str1 + str2",
      "tgt": "CONCAT(str1, str2)",
      "note": "MSSQL 문자열 연결 + → CONCAT(). NULL 포함 시 CONCAT_WS 고려",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_concat_null",
      "src": "CONCAT(str1, str2)",
      "tgt": "CONCAT(str1, str2)",
      "note": "CONCAT OK. MSSQL CONCAT은 NULL→'' 자동 변환, MySQL도 동일",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_concat_ws",
      "src": "CONCAT_WS(sep, str1, str2, ...)",
      "tgt": "CONCAT_WS(sep, str1, str2, ...)",
      "note": "CONCAT_WS OK — MySQL 8.0+",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_string_agg",
      "src": "STRING_AGG(col, sep)",
      "tgt": "GROUP_CONCAT(col SEPARATOR sep)",
      "note": "문자열 집계 — ORDER BY는 GROUP_CONCAT(col ORDER BY ... SEPARATOR sep)",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_string_agg_order",
      "src": "STRING_AGG(col, sep) WITHIN GROUP (ORDER BY col2)",
      "tgt": "GROUP_CONCAT(col ORDER BY col2 SEPARATOR sep)",
      "note": "정렬된 문자열 집계",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_format_number",
      "src": "FORMAT(number, 'N0')",
      "tgt": "FORMAT(number, 0)",
      "note": "숫자 포맷 — FORMAT(숫자, 소수자리수)",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_format_number2",
      "src": "FORMAT(number, 'N2')",
      "tgt": "FORMAT(number, 2)",
      "note": "소수 2자리 포맷",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_ascii",
      "src": "ASCII(char)",
      "tgt": "ASCII(char)",
      "note": "ASCII 코드 반환 OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_char",
      "src": "CHAR(n)",
      "tgt": "CHAR(n)",
      "note": "ASCII 코드 → 문자 OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_unicode",
      "src": "UNICODE(char)",
      "tgt": "ORD(char)",
      "note": "유니코드 코드포인트 반환",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_nchar",
      "src": "NCHAR(n)",
      "tgt": "CHAR(n USING utf8mb4)",
      "note": "유니코드 코드포인트 → 문자",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_string_escape",
      "src": "STRING_ESCAPE(str, 'json')",
      "tgt": "JSON_QUOTE(str)",
      "note": "JSON 이스케이프",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_quotename",
      "src": "QUOTENAME(str)",
      "tgt": "CONCAT('`', REPLACE(str, '`', '``'), '`')",
      "note": "식별자 인용 — MySQL 백틱으로 변환",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_like_escape",
      "src": "LIKE '%\\_%' ESCAPE '\\'",
      "tgt": "LIKE '%\\_%'",
      "note": "ESCAPE 절 — MySQL은 기본 이스케이프가 \\",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_regexp",
      "src": "str LIKE '%pattern%'",
      "tgt": "str LIKE '%pattern%'",
      "note": "LIKE OK",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_regexp_mssql",
      "src": "str LIKE 'pattern' COLLATE Latin1_General_CS_AS",
      "tgt": "BINARY str LIKE 'pattern'",
      "note": "대소문자 구분 LIKE → BINARY 또는 utf8mb4_bin collation",
      "warning": true,
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_collate",
      "src": "str COLLATE SQL_Latin1_General_CP1_CI_AS",
      "tgt": "str COLLATE utf8mb4_unicode_ci",
      "note": "Collation 변환 — MySQL collation 이름으로 변경 필요",
      "warning": true,
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_collate_cs",
      "src": "str COLLATE SQL_Latin1_General_CP1_CS_AS",
      "tgt": "str COLLATE utf8mb4_bin",
      "note": "대소문자 구분 Collation",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_translate",
      "src": "TRANSLATE(str, from_chars, to_chars)",
      "tgt": "-- MySQL 미지원. 중첩 REPLACE()로 구현 필요",
      "note": "TRANSLATE → MySQL 8.0.22 미만 미지원. 8.0.22+는 TRANSLATE() 지원",
      "warning": true,
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_trim_char",
      "src": "TRIM('x' FROM str)",
      "tgt": "TRIM(BOTH 'x' FROM str)",
      "note": "특정 문자 제거 TRIM",
      "category": "FUNCTION_STRING"
    },
    {
      "id": "fn_str_isnumeric",
      "src": "ISNUMERIC(str)",
      "tgt": "(str REGEXP '^[0-9]+(\\\\.[0-9]+)?$')",
      "note": "숫자 여부 확인 → REGEXP 사용",
      "category": "FUNCTION_STRING"
    }
  ]
}
