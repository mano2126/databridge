function _applySpacing(top, left, content) {
  const r = document.documentElement
  r.style.setProperty('--topbar-h',  top     + 'px')
  r.style.setProperty('--sidebar-w', left    + 'px')
  r.style.setProperty('--content-p', content + 'px')
}

function updateSpacing(axis, val) {
  const v = Math.round(Number(val))
  if (axis === 'top')     cfg.value.spacingTop     = v
  if (axis === 'left')    cfg.value.spacingLeft    = v
  if (axis === 'content') cfg.value.spacingContent = v
  _applySpacing(cfg.value.spacingTop ?? 44, cfg.value.spacingLeft ?? 240, cfg.value.spacingContent ?? 16)
  try { localStorage.setItem(SPACING_KEY, JSON.stringify({ top: cfg.value.spacingTop, left: cfg.value.spacingLeft, content: cfg.value.spacingContent })) } catch {}
}

function resetSpacing(axis) {
  if (axis === 'top')     cfg.value.spacingTop     = SPACING_DEFAULTS.top
  if (axis === 'left')    cfg.value.spacingLeft    = SPACING_DEFAULTS.left
  if (axis === 'content') cfg.value.spacingContent = SPACING_DEFAULTS.content
  _applySpacing(cfg.value.spacingTop ?? 44, cfg.value.spacingLeft ?? 240, cfg.value.spacingContent ?? 16)
  try { localStorage.setItem(SPACING_KEY, JSON.stringify({ top: cfg.value.spacingTop, left: cfg.value.spacingLeft, content: cfg.value.spacingContent })) } catch {}
}

