// ── Claude API 사용량 ──────────────────────────────────────
const claudeUsage  = ref(null)
const usageLoading = ref(false)

function _tsToKST(ts) {
  // ts 형식 다양: "2026.04.11T04:43:56.357681" / "2026-04-11 04:43:56" / ISO
  if (!ts) return null
  // T가 있으면 ISO 형식 → UTC로 인식해서 KST(+9) 변환
  // 공백 구분이면 로컬 저장값 → 그대로 파싱
  let normalized = ts.replace('.', '-').replace('.', '-')  // 2026.04.11 → 2026-04-11
  if (normalized.includes('T')) {
    // UTC → KST: Z 없으면 UTC로 간주하고 +9h
    let _sn = normalized.trim().replace(/([+-]\d{2}:\d{2})Z$/, '$1'); if(!_sn.includes('+')&&!_sn.endsWith('Z')) _sn=_sn.replace(' ','T')+'+09:00'
    const d = new Date(_sn)
    return isNaN(d) ? null : d
  } else {
    // 공백 구분 로컬 시간
    const d = new Date(normalized.replace(' ', 'T') + '+09:00')
    return isNaN(d) ? null : d
  }
}

function fmtUsageDate(ts) {
  const d = _tsToKST(ts)
  if (!d) return ts?.slice(0, 10) || ''
  const y  = d.getFullYear()
  const mo = String(d.getMonth() + 1).padStart(2, '0')
  const dd = String(d.getDate()).padStart(2, '0')
  return `${y}.${mo}.${dd}`
}

function fmtUsageTime(ts) {
  const d = _tsToKST(ts)
  if (!d) return ts?.slice(11, 19) || ''
  const hh = String(d.getHours()).padStart(2, '0')
  const mm = String(d.getMinutes()).padStart(2, '0')
  const ss = String(d.getSeconds()).padStart(2, '0')
  return `${hh}:${mm}:${ss}`
}

async function loadClaudeUsage() {
  usageLoading.value = true
  try {
    const { data } = await axios.get('/api/v1/settings/claude-usage')
    claudeUsage.value = data || null
  } catch(e) { console.error('사용량 조회 실패', e) }
  finally { usageLoading.value = false }
}

async function resetClaudeUsage() {
  if (!confirm('Claude API 사용 이력을 초기화할까요?')) return
  try {
    await axios.delete('/api/v1/settings/claude-usage')
    claudeUsage.value = null
    app.notify('사용 이력 초기화 완료', 'success')
  } catch(e) { app.notify('초기화 실패', 'error') }
}

