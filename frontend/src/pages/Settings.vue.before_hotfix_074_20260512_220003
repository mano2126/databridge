const showLogViewer    = ref(false)
const viewerSource     = ref('backend')
const viewerLines      = ref([])
// v90.35: 플로팅 창 상태 (non-blocking + 드래그 + 리사이즈 + 최소화)
//   본부장님 지적: "모달은 다른 작업 못 함 → 백그라운드 작업 가능한 창"
const viewerMinimized  = ref(false)
const floatPos         = ref({ x: 80, y: 80, w: 1100, h: 600 })
const floatStyle = computed(() => {
  if (viewerMinimized.value) {
    // 최소화 상태 - 우하단 작은 바 (헤더만)
    return {
      left: 'auto', top: 'auto',
      right: '20px', bottom: '20px',
      width: '320px', height: 'auto',
    }
  }
  return {
    left:  floatPos.value.x + 'px',
    top:   floatPos.value.y + 'px',
    width: floatPos.value.w + 'px',
    height: floatPos.value.h + 'px',
  }
})

// 드래그 핸들러
let _dragStart = null
function startDrag(ev) {
  // 버튼 클릭은 드래그 무시
  if (ev.target.closest('.lv-float-btn') || ev.target.closest('button')) return
  if (viewerMinimized.value) return
  _dragStart = {
    mouseX: ev.clientX, mouseY: ev.clientY,
    posX: floatPos.value.x, posY: floatPos.value.y,
  }
  document.addEventListener('mousemove', onDragMove)
  document.addEventListener('mouseup', endDrag)
  ev.preventDefault()
}
function onDragMove(ev) {
  if (!_dragStart) return
  const dx = ev.clientX - _dragStart.mouseX
  const dy = ev.clientY - _dragStart.mouseY
  floatPos.value.x = Math.max(0, Math.min(window.innerWidth - 200, _dragStart.posX + dx))
  floatPos.value.y = Math.max(0, Math.min(window.innerHeight - 60,  _dragStart.posY + dy))
}
function endDrag() {
  _dragStart = null
  document.removeEventListener('mousemove', onDragMove)
  document.removeEventListener('mouseup', endDrag)
}

// 리사이즈 핸들러
let _resizeStart = null
function startResize(ev) {
  _resizeStart = {
    mouseX: ev.clientX, mouseY: ev.clientY,
    w: floatPos.value.w, h: floatPos.value.h,
  }
  document.addEventListener('mousemove', onResizeMove)
  document.addEventListener('mouseup', endResize)
  ev.preventDefault()
  ev.stopPropagation()
}
function onResizeMove(ev) {
  if (!_resizeStart) return
  const dw = ev.clientX - _resizeStart.mouseX
  const dh = ev.clientY - _resizeStart.mouseY
  floatPos.value.w = Math.max(400, Math.min(window.innerWidth - 40,  _resizeStart.w + dw))
  floatPos.value.h = Math.max(200, Math.min(window.innerHeight - 40, _resizeStart.h + dh))
  // viewport height 도 갱신
  if (viewerBodyEl.value) viewerHeight.value = viewerBodyEl.value.clientHeight
}
function endResize() {
  _resizeStart = null
  document.removeEventListener('mousemove', onResizeMove)
  document.removeEventListener('mouseup', endResize)
}
const viewerLevelFilter = ref('')
const viewerSearch     = ref('')
const viewerFetchLines = ref(5000)
const viewerLoading    = ref(false)
const viewerBodyEl     = ref(null)

// 가상 스크롤 - LogViewer 팝업 전용
const VIEWER_LINE_HEIGHT = 18
const VIEWER_OVERSCAN = 20
const viewerScrollTop = ref(0)
const viewerHeight = ref(600)

const viewerFilteredLogs = computed(() => {
  let lines = viewerLines.value
  if (viewerLevelFilter.value) lines = lines.filter(l => l.includes(viewerLevelFilter.value))
  if (viewerSearch.value) {
    const q = viewerSearch.value.toLowerCase()
    lines = lines.filter(l => l.toLowerCase().includes(q))
  }
  return lines
})

const viewerStartIdx = computed(() => {
  const start = Math.floor(viewerScrollTop.value / VIEWER_LINE_HEIGHT) - VIEWER_OVERSCAN
  return Math.max(0, start)
})

const viewerEndIdx = computed(() => {
  const visible = Math.ceil(viewerHeight.value / VIEWER_LINE_HEIGHT) + VIEWER_OVERSCAN * 2
  return Math.min(viewerFilteredLogs.value.length, viewerStartIdx.value + visible)
})

const viewerVisibleLogs = computed(() => {
  return viewerFilteredLogs.value.slice(viewerStartIdx.value, viewerEndIdx.value)
})

const viewerOffsetTop = computed(() => viewerStartIdx.value * VIEWER_LINE_HEIGHT)
const viewerOffsetBottom = computed(() => {
  const remaining = viewerFilteredLogs.value.length - viewerEndIdx.value
  return Math.max(0, remaining * VIEWER_LINE_HEIGHT)
})

let _viewerScrollRaf = null
function onViewerScroll(ev) {
  if (_viewerScrollRaf) return
  _viewerScrollRaf = requestAnimationFrame(() => {
    viewerScrollTop.value = ev.target.scrollTop
    _viewerScrollRaf = null
  })
}

async function openLogViewer() {
  showLogViewer.value = true
  viewerSource.value = logSource.value  // 현재 보던 소스로 시작
  await nextTick()
  if (viewerBodyEl.value) viewerHeight.value = viewerBodyEl.value.clientHeight
  await loadViewerLogs()
}

function closeLogViewer() {
  showLogViewer.value = false
  // 메모리 정리
  viewerLines.value = []
  viewerScrollTop.value = 0
}

async function loadViewerLogs() {
  viewerLoading.value = true
  try {
    const {data} = await axios.get('/api/v1/settings/log-tail', {
      params: { lines: viewerFetchLines.value, source: viewerSource.value },
      timeout: 30000,  // 대용량 가져올 수도 있으니 30초
    })
    viewerLines.value = data.lines || []
    await nextTick()
    // 맨 아래(최신)로 스크롤
    if (viewerBodyEl.value) {
      viewerBodyEl.value.scrollTop = viewerBodyEl.value.scrollHeight
      viewerHeight.value = viewerBodyEl.value.clientHeight
    }
  } catch(e) {
    const errMsg = e.code === 'ECONNABORTED' ? '백엔드 응답 timeout (30초)'
                 : e.code === 'ERR_NETWORK' ? '백엔드 연결 실패'
                 : e.message
    viewerLines.value = [`[오류] 로그 읽기 실패: ${errMsg}`]
  } finally { viewerLoading.value = false }
}

function copyViewerLogs() {
  navigator.clipboard?.writeText(viewerFilteredLogs.value.join('\n'))
  app.notify('로그 복사됨', 'success')
}

const currentLogFile = computed(() =>
  logSource.value === 'backend'
    ? logInfoMap.value.backend?.file || cfg.value.backend_log_file
    : logInfoMap.value.frontend?.file || cfg.value.frontend_log_file
)

// v90.35: clearScreen 후 들어온 새 로그만 표시하는 마커
//   본부장님 지적: "화면초기화 후 다시 모두 나타나서 clear 역할을 못함"
//   원인: logLines=[] 해도 다음 polling 이 전체 로그 다시 채움
//   해결: clearMark 이후의 라인만 filteredLogs 에 노출
const clearAfterCount = ref(0)  // clear 시점의 logLines.length 기록

const filteredLogs = computed(() => {
  let lines = logLines.value
  // v90.35: clear 마커 적용 - 마커 이후 들어온 줄만 표시
  if (clearAfterCount.value > 0 && lines.length >= clearAfterCount.value) {
    // logLines 가 처음부터 다시 시작하면 마커보다 작아질 수 있음 - 그땐 무시
    lines = lines.slice(clearAfterCount.value)
  }
  if (logLevelFilter.value) lines = lines.filter(l => l.includes(logLevelFilter.value))
  if (logSearch.value) {
    const q = logSearch.value.toLowerCase()
    lines = lines.filter(l => l.toLowerCase().includes(q))
  }
  // v95_p9_REAL: 정렬 토글 - 최신 위 모드면 역순 반환
  //   본부장님 요청: "최신내용을 제일 위로 올려줘"
  //   slice() 로 새 배열 생성해야 reactive 정상 작동
  if (sortNewestFirst.value) {
    return lines.slice().reverse()
  }
  return lines
})

// v95_p9_REAL: 정렬 토글 핸들러
function toggleSort() {
  sortNewestFirst.value = !sortNewestFirst.value
  // 모드 변경 시 스크롤 위치 조정 (최신 라인이 보이게)
  nextTick(() => {
    if (logBodyEl.value) {
      if (sortNewestFirst.value) {
        // 최신 위 → 맨 위로
        logBodyEl.value.scrollTop = 0
      } else {
        // 시간순 → 맨 아래로
        logBodyEl.value.scrollTop = logBodyEl.value.scrollHeight
      }
    }
  })
  app.notify(sortNewestFirst.value ? '⬆ 최신 라인을 위로' : '⬇ 시간순 (오래된 라인이 위)', 'info')
}

// v95_p9_REAL: 화면 초기화 = 자동 백업 + 마커 설정 한방에
//   본부장님 요청: "화면 초기화 하면 백업시키고 깨끗하게 보여줘"
//   동작: (1) 현재 로그 압축 백업 (2) clearMark 설정으로 화면 비움
//   - 파일 자체는 그대로 유지 (rotateLog 와 다름) - 다음 폴링에서 채워짐
//   - 마커 이후 새 라인만 표시되므로 "깨끗하게" 보임
async function clearScreen() {
  if (!confirm('현재 로그를 백업하고 화면을 초기화합니다. 진행할까요?\n\n· 백업: logs/backups/ 에 압축 저장\n· 화면: 새 로그부터 표시 (이전 라인 숨김)\n· 파일: 보존 (계속 누적)')) return
  
  try {
    // 1) 자동 백업 (압축)
    const {data} = await axios.post('/api/v1/settings/log-backup', { compress: true })
    const cnt = (data.backups || []).length
    if (cnt > 0) {
      const names = (data.backups || [])
        .filter(b => b.path)
        .map(b => b.path.split(/[\\/]/).pop())
        .join(', ')
      app.notify(`💾 ${cnt}개 백업 완료 (${names}) — 화면 초기화됨`, 'success')
    } else {
      app.notify('빈 로그 — 백업 SKIP, 화면만 초기화', 'info')
    }
    // 2) 백업 목록 갱신
    await loadBackups()
  } catch(e) {
    app.notify('백업 실패: '+e.message+' — 화면만 초기화합니다', 'warn')
  }
  
  // 3) 마커 설정 (이후 들어오는 줄만 표시)
  clearAfterCount.value = logLines.value.length
}

// ════════════════════════════════════════════════════════════════
// v90.28: 가상 스크롤 (Virtual Scrolling)
// ════════════════════════════════════════════════════════════════
//   본부장님 보고: "로그 2MB 정도면 화면 거의 죽음"
//   원인: v-for 가 모든 줄 (3~5만개) DOM 생성 → 브라우저 마비
//   해결: 보이는 영역 (~80~120 줄) 만 실제 DOM, 위/아래 spacer 로 스크롤 흉내
//
//   효과: 100만 줄도 부드럽게 동작
const LOG_LINE_HEIGHT = 18      // 한 줄 픽셀 높이 (CSS 와 일치)
const LOG_OVERSCAN = 20         // 보이는 영역 위/아래 미리 렌더할 줄 수

const logScrollTop = ref(0)
const logViewportHeight = ref(600)  // lv-body 컨테이너 높이

// 보이는 시작/끝 인덱스
const virtualStartIdx = computed(() => {
  const start = Math.floor(logScrollTop.value / LOG_LINE_HEIGHT) - LOG_OVERSCAN
  return Math.max(0, start)
})

const virtualEndIdx = computed(() => {
  const visible = Math.ceil(logViewportHeight.value / LOG_LINE_HEIGHT) + LOG_OVERSCAN * 2
  return Math.min(filteredLogs.value.length, virtualStartIdx.value + visible)
})

// 실제 DOM 에 렌더링할 줄들
const visibleLogs = computed(() => {
  return filteredLogs.value.slice(virtualStartIdx.value, virtualEndIdx.value)
})

// 위/아래 spacer 높이
const virtualOffsetTop = computed(() => virtualStartIdx.value * LOG_LINE_HEIGHT)
const virtualOffsetBottom = computed(() => {
  const remaining = filteredLogs.value.length - virtualEndIdx.value
  return Math.max(0, remaining * LOG_LINE_HEIGHT)
})

// 스크롤 이벤트 - throttled (RAF 기반)
let _scrollRaf = null
function onLogScroll(ev) {
  if (_scrollRaf) return  // 다음 프레임 까진 무시
  _scrollRaf = requestAnimationFrame(() => {
