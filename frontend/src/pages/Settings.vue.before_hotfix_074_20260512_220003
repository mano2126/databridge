// v9 패치 #18: 로그 백업
function fmtBytes(n) {
  if (!n) return '0 B'
  const u = ['B','KB','MB','GB']
  let i = 0
  while (n >= 1024 && i < u.length-1) { n/=1024; i++ }
  return n.toFixed(n>=10?0:1) + ' ' + u[i]
}

