<script setup>
import { ref, computed, onMounted, onUnmounted, watch } from 'vue'
import axios from 'axios'

const API_BASE = '/api/logs'

// 본문
const loading = ref(false)
const lines = ref([])
const fileInfo = ref('')
const sizeKb = ref(0)

// 필터
const level = ref('ALL')
const keyword = ref('')
const lineCount = ref(500)
const autoRefresh = ref(false)
let refreshTimer = null

// hotfix_099: 상단 상태
const fileLoggingEnabled = ref(false)
const logLevel = ref('INFO')

// 패널 (모달 대신 인라인) — null | 'rotation' | 'archives'
const panel = ref(null)
const settings = ref({ size_mb: 5, interval_hours: 1, retention_days: 30 })

const archives = ref([])
const archiveContent = ref(null)

const filteredLines = computed(() => lines.value)

function rowClass(row) {
  if (row.includes('[ERROR]') || row.includes('[CRITICAL]')) return 'lv-row-error'
  if (row.includes('[WARNING]')) return 'lv-row-warn'
  if (row.includes('[DEBUG]')) return 'lv-row-debug'
  return 'lv-row-info'
}

function togglePanel(name) {
  panel.value = panel.value === name ? null : name
  archiveContent.value = null
}

async function loadLog() {
  loading.value = true
  try {
    const res = await axios.get(`${API_BASE}/tail`, {
      params: { lines: lineCount.value, level: level.value, keyword: keyword.value }
    })
    lines.value = res.data.lines || []
    fileInfo.value = res.data.file || ''
    sizeKb.value = res.data.size_kb || 0
  } catch (e) {
    lines.value = [`[CLIENT ERROR] 로그 조회 실패: ${e.message}`]
  } finally {
    loading.value = false
  }
}

async function loadSettingsFromServer() {
  try {
    const res = await axios.get(`${API_BASE}/settings`)
    const s = res.data || {}
    settings.value.size_mb = s.size_mb ?? 5
    settings.value.interval_hours = s.interval_hours ?? 1
    settings.value.retention_days = s.retention_days ?? 30
    // hotfix_099: 토글 상태 동기화
    fileLoggingEnabled.value = !!s.file_logging_enabled
    logLevel.value = s.log_level || 'INFO'
  } catch (e) { /* silent */ }
}

async function saveSettings() {
  try {
    await axios.post(`${API_BASE}/settings`, {
      size_mb: settings.value.size_mb,
      interval_hours: settings.value.interval_hours,
      retention_days: settings.value.retention_days,
    })
    panel.value = null
    alert('회전 설정 저장 완료 — 다음 회전부터 적용됩니다.')
    loadLog()
  } catch (e) {
    alert(`저장 실패: ${e.message}`)
  }
}

// hotfix_099: 파일 로깅 토글 (트레이와 동일 endpoint)
async function toggleFileLogging() {
  const newValue = !fileLoggingEnabled.value
  try {
    await axios.post(`${API_BASE}/toggle`, {
      file_logging_enabled: newValue,
    })
    fileLoggingEnabled.value = newValue
    setTimeout(loadLog, 300)
  } catch (e) {
    alert(`토글 실패: ${e.message}`)
  }
}

async function changeLogLevel() {
  try {
    await axios.post(`${API_BASE}/toggle`, {
      log_level: logLevel.value,
    })
  } catch (e) {
    alert(`레벨 변경 실패: ${e.message}`)
  }
}

function confirmClear() {
  if (!fileLoggingEnabled.value) {
    alert('파일 로깅이 OFF 상태입니다. 먼저 기록을 시작해주세요.')
    return
  }
  if (!confirm('현재 로그를 백업 후 화면/파일 모두 초기화합니다. 진행할까요?')) return
  axios.post(`${API_BASE}/clear`).then((res) => {
    alert(`초기화 완료\n백업: ${res.data.archived_to || '(빈 파일)'}`)
    loadLog()
    loadArchives(false)
  }).catch((e) => alert(`실패: ${e.message}`))
}

async function loadArchives(openPanel = true) {
  try {
    const res = await axios.get(`${API_BASE}/archives`)
    archives.value = res.data.archives || []
    if (openPanel) panel.value = 'archives'
  } catch (e) { /* silent */ }
}

async function viewArchive(name) {
  try {
    const res = await axios.get(`${API_BASE}/archive/${encodeURIComponent(name)}`, {
      params: { lines: 2000 }
    })
    archiveContent.value = res.data
  } catch (e) {
    alert(`백업 조회 실패: ${e.message}`)
  }
}

async function manualCleanup() {
  try {
    const res = await axios.post(`${API_BASE}/cleanup`)
    alert(`정리 완료: ${res.data.deleted}건 삭제`)
    loadArchives(false)
  } catch (e) {
    alert(`정리 실패: ${e.message}`)
  }
}

watch(autoRefresh, (v) => {
  if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null }
  if (v) refreshTimer = setInterval(loadLog, 5000)
})

onMounted(() => {
  loadLog()
  loadSettingsFromServer()
  loadArchives(false)
})

onUnmounted(() => {
  if (refreshTimer) clearInterval(refreshTimer)
})
</script>

