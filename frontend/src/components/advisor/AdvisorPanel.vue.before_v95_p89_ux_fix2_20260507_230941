async function runAnalysis(forceFresh = false) {
  analyzing.value = true
  try {
    // hotfix 2026-04-23: connectorStore 의 연결 정보를 body 에 포함
    //   백엔드 _get_source_connection 이 schema._conns fallback 대신 우선 사용.
    //   connectorStore.source / .target 에는 위저드 연결 테스트 후 저장된 값이 있음.
    const src = connector.source || {}
    const tgt = connector.target || {}
    const toConnInfo = (c) => ({
      host:     c.host,
      port:     c.port,
      username: c.username,
      password: c.password,
      database: c.database,
      db_type:  c.dbType,
    })

    const { data } = await axios.post('/api/v1/advisor/analyze', {
      src_db:  props.srcDb,
      tgt_db:  props.tgtDb,
      selection: {
        tables:     props.selection.tables     || [],
        procedures: props.selection.procedures || [],
        functions:  props.selection.functions  || [],
        triggers:   props.selection.triggers   || [],
        views:      props.selection.views      || [],
      },
      mode: selectedMode.value,
      user_hints: '',
      source_conn: src.host ? toConnInfo(src) : null,
      target_conn: tgt.host ? toConnInfo(tgt) : null,
      // v88 hotfix2 (2026-04-23): 마스킹된 비번 복원용 profile_id
      //   프로파일 로드 시 connectorStore 에 저장되는 ID.
      //   없으면(직접 입력 모드) null — password 가 이미 평문이므로 복원 불필요.
      profile_id: connector.loadedProfileId || null,
      // v95_p18_cache (2026-05-03 본부장님 본질 처방): 캐시 사용 여부
      //   forceFresh=true → 강제 새 분석 (사용자가 "🔄 새로 분석" 클릭)
      //   기본 false → 같은 입력이면 캐시에서 반환 (비용 0, 즉시)
      use_cache: !forceFresh,
    })

    recommendations.value = data.recommendations || []
    summary.value         = data.summary || {}
    advisorStatus.value   = data.advisor_status || {}

    // v95_p18_cache: 캐시 메타 정보 저장 (UI 입증 표시용)
    fromCache.value = !!data.from_cache
    cachedAt.value  = data.cached_at || ''

    // 초기 결정: 각 권고의 default_action 을 초기값으로
    const initialDecisions = {}
    for (const r of recommendations.value) {
      initialDecisions[r.id] = r.default_action === 'apply' ? 'applied' : 'pending'
    }
    decisionMap.value = initialDecisions
    editedSqlMap.value = {}

    // 첫 번째 권고 있는 탭으로 자동 이동
    for (const cat of ['server', 'table', 'object', 'index']) {
      if ((countByCategory.value[cat] || 0) > 0) {
        activeCategory.value = cat
        break
      }
    }

    analyzed.value = true
    emit('update:mode', selectedMode.value)
    emitDecisions()
    
    // v90.20: 분석 결과 전체를 부모로 emit (sessionStorage 보존용)
    emit('update:analysis', {
      analyzed: true,
      mode: selectedMode.value,
      recommendations: recommendations.value,
      summary: summary.value,
      advisorStatus: advisorStatus.value,
      decisionMap: { ...decisionMap.value },
      editedSqlMap: { ...editedSqlMap.value },
      activeCategory: activeCategory.value,
      selectedRecId: selectedRecId.value,
    })

  } catch (e) {
    console.error('[advisor] analysis failed:', e)
    alert(`분석 실패: ${e.response?.data?.detail || e.message}`)
  } finally {
    analyzing.value = false
  }
}

