// 현재 탭에서 체크된(=applied/edited) 개수
const selectedInCategoryCount = computed(() => {
  let n = 0
  for (const r of filteredRecs.value) {
    const d = decisionMap.value[r.id]
    if (d === 'applied' || d === 'edited') n++
  }
