// v95_p18_cache (2026-05-03 본부장님 본질 처방): 캐시 무시 강제 새 분석
//   사용자가 "🔄 새로 분석" 버튼 클릭 → use_cache=false 로 호출
//   AI 가 새로 분석 → 캐시 갱신 → from_cache=false 로 응답
async function runFreshAnalysis() {
