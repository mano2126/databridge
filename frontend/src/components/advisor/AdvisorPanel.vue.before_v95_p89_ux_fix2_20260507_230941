}

// ── 결정 관리 ──
function setDecision(id, val) {
  decisionMap.value = { ...decisionMap.value, [id]: val }
  emitDecisions()
}

function setEditedSql(id, sql) {
  editedSqlMap.value = { ...editedSqlMap.value, [id]: sql }
  emitDecisions()
}

function applyAll(scope) {
  const next = {}
  for (const rec of recommendations.value) {
    if (scope === 'high-med' && (rec.severity === 'high' || rec.severity === 'med')) {
      next[rec.id] = 'applied'
    } else if (scope === 'recommended' && rec.default_action === 'apply') {
      next[rec.id] = 'applied'
    } else {
      // 유지 (기존 결정이 있으면 그대로, 없으면 pending)
      next[rec.id] = decisionMap.value[rec.id] || 'pending'
    }
  }
  decisionMap.value = next
  emitDecisions()
}

function skipAll() {
  const next = {}
  for (const rec of recommendations.value) {
    next[rec.id] = 'skipped'
  }
  decisionMap.value = next
  emitDecisions()
}

// ─── 2026-04-23 UX 개편: 3분할 뷰용 액션 ───────────────────
// 체크박스 하나 토글: applied ↔ pending
function toggleDecision(id, checked) {
  const next = { ...decisionMap.value }
  if (checked) {
    // 이미 edited 이면 유지(수정 내용 보존), 아니면 applied
    if (next[id] !== 'edited') next[id] = 'applied'
  } else {
    // 체크 해제 — edited/applied → pending
    if (next[id] === 'applied' || next[id] === 'edited') {
      next[id] = 'pending'
    }
  }
  decisionMap.value = next
  emitDecisions()
}

// 건너뜀 명시 토글 (Before/After 화면에서)
function toggleSkip(id, checked) {
  const next = { ...decisionMap.value }
  if (checked) {
    next[id] = 'skipped'
  } else if (next[id] === 'skipped') {
    next[id] = 'pending'
  }
  decisionMap.value = next
  emitDecisions()
}

// 현재 탭 전체 선택 (applied)
function selectAll() {
  const next = { ...decisionMap.value }
  for (const rec of filteredRecs.value) {
    if (next[rec.id] !== 'edited') next[rec.id] = 'applied'
  }
  decisionMap.value = next
  emitDecisions()
}

// 현재 탭 전체 해제 (pending)
function deselectAll() {
  const next = { ...decisionMap.value }
  for (const rec of filteredRecs.value) {
    if (next[rec.id] === 'applied' || next[rec.id] === 'edited') {
      next[rec.id] = 'pending'
    }
  }
  decisionMap.value = next
  emitDecisions()
}

// 심각도 기반 선택 — 'high' 단일 or ['high','med'] 배열
function selectBySev(sev) {
  const targets = Array.isArray(sev) ? sev : [sev]
  const next = { ...decisionMap.value }
  for (const rec of filteredRecs.value) {
    if (targets.includes(rec.severity)) {
      if (next[rec.id] !== 'edited') next[rec.id] = 'applied'
    } else {
      // 나머지는 건드리지 않음 (이미 체크된 것 보존)
    }
  }
  decisionMap.value = next
  emitDecisions()
}

// After 패널 편집 모드
function startEdit() {
  if (!selectedRec.value) return
  editMode.value = true
  editDraft.value = editedSqlMap.value[selectedRec.value.id] || selectedRec.value.after || ''
}

function saveEdit() {
  if (!selectedRec.value) return
  const id = selectedRec.value.id
  editedSqlMap.value = { ...editedSqlMap.value, [id]: editDraft.value }
  // 편집 저장하면 결정이 'edited' 로 승격 (체크 상태 유지)
  decisionMap.value = { ...decisionMap.value, [id]: 'edited' }
  editMode.value = false
  emitDecisions()
}

function cancelEdit() {
  editMode.value = false
  editDraft.value = ''
}

function emitDecisions() {
  // 부모 form 에 전달
  // v10 #23 (2026-04-24): title/description 도 전달 → 백엔드 baseline 정확도 향상
  const list = recommendations.value.map(rec => ({
    id: rec.id,
    category: rec.category,
    severity: rec.severity,
    decision: decisionMap.value[rec.id] || 'pending',
    edited_sql: editedSqlMap.value[rec.id] || '',
    // v10 #23 추가 — advisor_tracking baseline 생성에 사용됨
    title: rec.title || '',
    description: rec.description || '',
  }))
  emit('update:decisions', list)

  // ─────────────────────────────────────────────────────────────
  // v94_p1 (2026-05-01): 본부장님 호소 — "토글이 동작 안 하는 것 같다"
  //
  // 기존: emit 만 했고 백엔드 호출은 submit() 시점에만 발생
  //  → 사용자가 클릭해도 실제 백엔드에 즉시 안 가서 UI 가 동작 안 하는 것처럼 보임
  //
  // 처방: 결정 변경 시 백엔드 /advisor/apply-decision 즉시 호출 (debounce 800ms)
  //       응답 받아서 lastApplyResult 에 저장 → UI 에 ✓ 적용 N개 표시
  // ─────────────────────────────────────────────────────────────
  scheduleApplyDecisions(list)
}

// v94_p1: debounce 한 백엔드 호출
let _applyDecisionsTimer = null
function scheduleApplyDecisions(list) {
  if (_applyDecisionsTimer) clearTimeout(_applyDecisionsTimer)
  _applyDecisionsTimer = setTimeout(() => {
    callApplyDecisions(list)
  }, 800)
}

// v94_p1: 백엔드 즉시 호출 + 시각 피드백
const applyState = ref({ saving: false, lastSaved: null, error: null, stats: null })
async function callApplyDecisions(list) {
  // pending 빼고 실제 결정한 것만 전송 (적용/거부/편집 중 하나)
  const decided = list.filter(d => d.decision && d.decision !== 'pending')
  if (decided.length === 0) {
    // 모두 pending — 저장할 게 없음. lastSaved 표시 초기화.
    applyState.value = { saving: false, lastSaved: null, error: null, stats: null }
    return
  }
  applyState.value = { ...applyState.value, saving: true, error: null }
  try {
    const { data } = await axios.post('/api/v1/advisor/apply-decision', {
      src_db: props.srcDb,
      tgt_db: props.tgtDb,
      mode: selectedMode.value,
      job_id: '',  // wizard 단계라 아직 jobId 없음 — 백엔드는 빈 문자열 허용
      decisions: decided,
    }, { timeout: 8000 })
    applyState.value = {
      saving: false,
      lastSaved: new Date(),
      error: null,
      stats: data?.stats || null,
    }
    console.log('[advisor.apply-decision] saved:', data)
  } catch (e) {
    applyState.value = {
      ...applyState.value,
      saving: false,
      error: e?.message || '저장 실패',
    }
    console.error('[advisor.apply-decision] failed:', e)
  }
}

// ── 생명주기 ──
onMounted(() => {
  // v95_p89_ux (2026-05-07 본부장님): AI Provider 먼저 로드 → 비용 표시 정확히
  loadAiProvider()
  
  estimateCosts()
  
  // v95_p21 (2026-05-03 본부장님 본질 처방): 캐시 사전 확인
  //   본부장님 호소: "비용절감 관련은 언제 화면에 나오는거야?"
  //   처방: 화면 진입 시 즉시 캐시 확인 → 비용 화면에 결과 표시
  checkCachePrecheck()
  
  // v90.20: 부모에서 전달된 분석 결과 복원 (sessionStorage 에서 살아남은 상태)
  if (props.initialAnalysis && props.initialAnalysis.analyzed) {
    const a = props.initialAnalysis
    selectedMode.value     = a.mode || 'smart'
    recommendations.value  = a.recommendations || []
    summary.value          = a.summary || {}
    advisorStatus.value    = a.advisorStatus || {}
    decisionMap.value      = { ...(a.decisionMap || {}) }
    editedSqlMap.value     = { ...(a.editedSqlMap || {}) }
    activeCategory.value   = a.activeCategory || 'server'
    selectedRecId.value    = a.selectedRecId || null
    analyzed.value         = true
    console.log('[AdvisorPanel] 분석 결과 복원:', recommendations.value.length, '개 권고')
  }

  // v94_p1: "N초 전" 표시 매초 갱신
  _tickTimer = setInterval(() => { _tick.value++ }, 1000)
})

// ════════════════════════════════════════════════════════════════
// v95_p89_ux (2026-05-07 본부장님): AI Provider 로딩
// ════════════════════════════════════════════════════════════════
async function loadAiProvider() {
  try {
    const r = await fetch('/api/v1/settings/', { credentials: 'include' })
    if (r.ok) {
      const cfg = await r.json()
      aiProvider.value = (cfg.ai_provider || 'anthropic').toLowerCase()
      aiProviderModel.value = cfg.ollama_model || ''
      console.log('[AdvisorPanel v95_p89_ux] AI Provider 인지:', 
                   aiProvider.value, aiProviderModel.value)
    }
  } catch (e) {
    console.warn('[AdvisorPanel] AI Provider 로드 실패 (anthropic 기본 사용):', e.message)
  }
}

// v94_p1: 컴포넌트 종료 시 ticker / debounce 타이머 정리
onUnmounted(() => {
  if (_tickTimer) clearInterval(_tickTimer)
  if (_applyDecisionsTimer) clearTimeout(_applyDecisionsTimer)
})

watch(
  () => [
    props.selection.tables?.length,
    props.selection.procedures?.length,
    props.selection.functions?.length,
    props.selection.views?.length,
    props.selection.triggers?.length,
  ],
  () => {
    estimateCosts()
    // v95_p21: 선택 객체 변경 시 캐시 상태 다시 확인
    checkCachePrecheck()
  }
)

// v95_p21: 모드 변경 시 캐시 상태 다시 확인 (smart/hybrid/deep 별 다른 캐시 키)
watch(selectedMode, () => {
  checkCachePrecheck()
})

// 2026-04-23 UX 개편: 카테고리 탭이나 검색 결과가 바뀌면 첫 권고 자동 선택
watch(filteredRecs, (list) => {
  if (!list || list.length === 0) {
    selectedRecId.value = null
    return
  }
  // 현재 선택이 필터된 리스트에 없으면 첫 번째로 자동 이동
  const stillVisible = list.some(r => r.id === selectedRecId.value)
  if (!stillVisible) {
    selectedRecId.value = list[0].id
  }
  // 카테고리 탭 전환 시 편집 모드 해제
  editMode.value = false
})

// v90.20: 사용자 인터랙션 (카테고리 탭/권고 선택/결정) 변경 시 부모로 emit
//         → sessionStorage 에 보존됨
watch([activeCategory, selectedRecId, decisionMap, editedSqlMap], () => {
  if (analyzed.value) {
    emit('update:analysis', {
      analyzed: true,
      mode: selectedMode.value,
      recommendations: recommendations.value,
      summary: summary.value,
      advisorStatus: advisorStatus.value,
      decisionMap: { ...decisionMap.value },
      editedSqlMap: { ...editedSqlMap.value },
      activeCategory: activeCategory.value,
      selectedRecId: selectedRecId.value,
    })
  }
}, { deep: true })

// 분석 완료 시점에 첫 권고 자동 선택
watch(analyzed, (v) => {
  if (v && filteredRecs.value.length > 0) {
    selectedRecId.value = filteredRecs.value[0].id
  }
})
</script>

