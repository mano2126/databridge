// 적용 방법 안내 - 기존 RecommendationCard 로직을 여기에 인라인
function howtoNeedsDba(rec) {
  if (!rec) return false
  const target = (rec.target || '').toLowerCase()
  if (rec.category === 'server') return true
  if (target.includes('my.cnf') || target.includes('postgresql.conf')) return true
  return false
}

function howtoManualHint(rec) {
  if (!rec) return ''
  const cat = rec.category
  const target = (rec.target || '').toLowerCase()
  if (target.includes('my.cnf') || target.includes('postgresql.conf')) {
    return 'my.cnf 수정 → DB 서버 재시작'
  }
  if (cat === 'table') {
    const t = rec.title || ''
    if (t.includes('파티셔닝')) return '이관 전 타겟 DDL 반영 또는 이관 후 ALTER TABLE'
    if (t.includes('오버스펙')) return '실사용 길이 측정 후 ALTER TABLE MODIFY COLUMN'
    if (t.includes('BINARY') || t.includes('GUID')) return '이관 DDL + 앱 코드 수정'
    return '타겟 DB에서 ALTER TABLE 실행'
  }
  if (cat === 'index') {
    const t = rec.title || ''
    if (t.includes('중복')) return '타겟 DB에서 DROP INDEX 실행'
    if (t.includes('누락') || t.includes('필수')) return '이관 완료 후 CREATE INDEX 실행'
    if (t.includes('과다')) return '사용량 측정 후 불필요 인덱스 DROP'
    return '타겟 DB에서 인덱스 DDL 실행'
  }
  if (cat === 'object') return 'SP/View DDL 재작성 후 재배포'
  if (cat === 'server') return '타겟 DB 설정 수정 또는 SET GLOBAL'
  return '권고 내용을 타겟 DB에 수동 반영'
}

