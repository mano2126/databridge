/* ══════════════════════════════════════════════════════════════
   3분할 메인 — 2026-04-23 스크롤 수정
   ══════════════════════════════════════════════════════════════ */
.adv-three-col {
  display: grid;
  grid-template-columns: 30% 35% 35%;
  gap: 10px;
  /* 명확한 고정 높이 — 그래야 자식의 overflow 가 동작 */
  height: 70vh;
  min-height: 480px;
  max-height: 760px;
}
@media (max-width: 1200px) {
  .adv-three-col {
    grid-template-columns: 35% 32.5% 32.5%;
  }
}
.adv-col {
  display: flex;
  flex-direction: column;
  border: 1px solid var(--border-light, #e2e8f0);
  border-radius: 8px;
  background: var(--bg-primary, #fff);
  overflow: hidden;   /* 내부 스크롤 영역과 헤더 경계 */
  min-height: 0;       /* flex 자식이 부모 높이 벗어나지 않도록 */
  min-width: 0;        /* grid 자식 동일 원리 */
}
.adv-col-header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 12px;
  background: var(--bg-secondary, #f8fafc);
  border-bottom: 1px solid var(--border-light, #e2e8f0);
  flex-shrink: 0;   /* 헤더는 스크롤해도 줄어들지 않음 */
}
.adv-col-title {
  font-size: 11.5px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 0.02em;
}
.adv-col-sub {
  font-size: 10.5px;
  color: var(--text-tertiary);
  margin-left: auto;
  font-weight: 500;
}
.adv-col-sub-sev {
  padding: 2px 7px;
  border-radius: 9px;
  font-weight: 700;
}
.adv-col-sub-sev.sev-high { background: rgba(220, 38, 38, 0.1); color: #991b1b; }
.adv-col-sub-sev.sev-med  { background: rgba(245, 158, 11, 0.1); color: #b45309; }
.adv-col-sub-sev.sev-low  { background: rgba(59, 130, 246, 0.1); color: #1d4ed8; }

.adv-col-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 20px;
  color: var(--text-tertiary);
  font-size: 12px;
  text-align: center;
  line-height: 1.6;
}
.adv-col-empty-ico {
  font-size: 32px;
  opacity: 0.4;
}

/* ─── 열 1: 권고 리스트 (2026-04-23 UX: 스크롤 강화 + 헤더 체크박스) ─── */
.adv-col-list-header {
  gap: 10px;
}
.adv-list-all-check {
  display: inline-flex;
  cursor: pointer;
  padding: 1px;
  user-select: none;
}
.adv-list-all-check input { display: none; }
.adv-list-all-box {
  display: inline-block;
  width: 16px; height: 16px;
  border: 1.5px solid var(--border-medium, #cbd5e1);
  border-radius: 3px;
  background: var(--bg-primary, #fff);
  position: relative;
}
.adv-list-all-check:hover .adv-list-all-box { border-color: #6d28d9; }
/* 전체 선택 상태 — 꽉 찬 체크 */
.adv-list-all-box.state-all {
  background: #6d28d9;
  border-color: #6d28d9;
}
.adv-list-all-box.state-all::after {
  content: '';
  position: absolute;
  left: 4px; top: 1px;
  width: 5px; height: 9px;
  border: solid #fff;
  border-width: 0 1.8px 1.8px 0;
  transform: rotate(45deg);
}
/* 부분 선택 상태 — 가로 막대 */
.adv-list-all-box.state-partial {
  background: #6d28d9;
  border-color: #6d28d9;
}
.adv-list-all-box.state-partial::after {
  content: '';
  position: absolute;
  left: 3px; top: 6px;
  width: 8px; height: 2.5px;
  background: #fff;
  border-radius: 1px;
}
.adv-list-count {
  display: flex; align-items: baseline; gap: 3px;
  font-variant-numeric: tabular-nums;
}
.adv-list-count-sel {
  font-weight: 700; color: #6d28d9;
  font-size: 12px;
}
.adv-list-count-total {
  color: var(--text-tertiary);
}

.adv-rec-list {
  list-style: none;
  padding: 4px;
  margin: 0;
  /* 핵심 수정: 명시적 overflow + 강한 flex 지정 + 최소 높이 차단 */
  overflow-y: auto;
  overflow-x: hidden;
  flex: 1 1 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
  /* 스크롤바 커스터마이즈 (webkit) */
  scrollbar-width: thin;
  scrollbar-color: var(--border-medium, #cbd5e1) transparent;
}
.adv-rec-list::-webkit-scrollbar { width: 6px; }
.adv-rec-list::-webkit-scrollbar-track { background: transparent; }
.adv-rec-list::-webkit-scrollbar-thumb {
  background: var(--border-medium, #cbd5e1);
  border-radius: 3px;
}
.adv-rec-list::-webkit-scrollbar-thumb:hover {
  background: #6d28d9;
}
.adv-rec-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 9px;
  border-radius: 5px;
  cursor: pointer;
  border-left: 3px solid transparent;
  transition: background 0.1s, border-color 0.1s;
  user-select: none;
}
.adv-rec-item:hover {
  background: var(--bg-secondary, #f8fafc);
}
.adv-rec-item.is-selected {
  background: rgba(109, 40, 217, 0.08);
  border-left-color: #6d28d9;
}
.adv-rec-item.is-applied:not(.is-selected) {
  background: rgba(22, 163, 74, 0.04);
}
.adv-rec-item.is-skipped {
  opacity: 0.5;
}
.adv-rec-item.sev-high { border-left-color: #dc2626; }
.adv-rec-item.sev-med  { border-left-color: #f59e0b; }
