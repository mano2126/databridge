})

// 2026-04-23 UX: 리스트 헤더 3-state 체크박스용
//   'all'     — 전부 선택됨 → ✓
//   'partial' — 일부만 선택됨 → ▣ (indeterminate)
//   'none'    — 하나도 선택 안 됨 → ☐
const allState = computed(() => {
  const total = filteredRecs.value.length
  if (total === 0) return 'none'
  const sel = selectedInCategoryCount.value
  if (sel === 0) return 'none'
  if (sel === total) return 'all'
  return 'partial'
})

function toggleAll(checked) {
  if (checked) {
    selectAll()
  } else {
    deselectAll()
  }
}

// ════════════════════════════════════════════════════════════════════════
// v90.57 (2026-04-28): 카테고리 탭 재클릭 토글
//   본부장님 요청: 카테고리 버튼 클릭 = 해당 카테고리 항목 전체 선택 ↔ 전체 해제
//   설계: 다른 카테고리는 이동만, 활성 카테고리 재클릭만 토글 (의도치 않은 변경 방지)
// ════════════════════════════════════════════════════════════════════════

// 각 카테고리의 선택 상태 ('all' | 'partial' | 'none') 표시용
//   - 검색/정렬 무관하게 카테고리 전체 항목 기준으로 판단 (filteredRecs 아님)
//   - 카테고리 탭 클릭 시 토글 동작의 기준이 됨
const categorySelectionState = computed(() => {
  const state = {}
  for (const cat of categoryTabs.value) {
    const recs = recommendations.value.filter(r => r.category === cat.v)
    if (recs.length === 0) {
      state[cat.v] = 'none'
      continue
    }
    let sel = 0
    for (const r of recs) {
      const d = decisionMap.value[r.id]
      if (d === 'applied' || d === 'edited') sel++
    }
    if (sel === 0) state[cat.v] = 'none'
    else if (sel === recs.length) state[cat.v] = 'all'
    else state[cat.v] = 'partial'
  }
  return state
})

// 카테고리 단위 일괄 선택 (검색/정렬 무관 — 카테고리 전체 항목 처리)
function selectAllInCategory(catId) {
  const next = { ...decisionMap.value }
  let touched = 0
  for (const rec of recommendations.value) {
    if (rec.category !== catId) continue
    if (next[rec.id] !== 'edited') {
      next[rec.id] = 'applied'
      touched++
    }
  }
  decisionMap.value = next
  emitDecisions()
  return touched
}

// 카테고리 단위 일괄 해제
function deselectAllInCategory(catId) {
  const next = { ...decisionMap.value }
  let touched = 0
  for (const rec of recommendations.value) {
    if (rec.category !== catId) continue
    if (next[rec.id] === 'applied' || next[rec.id] === 'edited') {
      next[rec.id] = 'pending'
      touched++
    }
  }
  decisionMap.value = next
  emitDecisions()
  return touched
}

// 카테고리 탭 클릭 핸들러 (v90.57)
//   - 다른 카테고리: 그 카테고리로 이동 (기존 동작 유지)
//   - 활성 카테고리 재클릭:
//       partial / none → 전체 선택
//       all            → 전체 해제 (토글)
function onCategoryClick(cat) {
  if (cat.status === 'pending' || cat.status === 'unsupported') return
  
  // 다른 카테고리 클릭 → 이동만 (선택 상태 변경 없음)
  if (activeCategory.value !== cat.v) {
    activeCategory.value = cat.v
    return
  }
  
  // 활성 카테고리 재클릭 → 토글
  // ok 상태가 아니면 무시 (분석 안 됨)
  if (cat.status !== 'ok') return
  const total = countByCategory.value[cat.v] || 0
  if (total === 0) return  // 항목 없으면 무시
  
  const state = categorySelectionState.value[cat.v]
  if (state === 'all') {
    deselectAllInCategory(cat.v)
  } else {
    // none / partial → 전체 선택
    selectAllInCategory(cat.v)
  }
}

const decisionCounts = computed(() => {
  const c = { applied: 0, skipped: 0, edited: 0, pending: 0 }
  for (const rec of recommendations.value) {
    const d = decisionMap.value[rec.id] || 'pending'
    c[d] = (c[d] || 0) + 1
  }
  return c
})

// v94_p1: 마지막 저장 시각 표시 ("방금" / "5초 전" / "1분 전")
//   tick ref 를 1초마다 증가시켜 computed 가 자동 재평가되게 함
const _tick = ref(0)
let _tickTimer = null
const savedTimeText = computed(() => {
  _tick.value  // dependency
  if (!applyState.value.lastSaved) return ''
  const sec = Math.floor((Date.now() - applyState.value.lastSaved.getTime()) / 1000)
  if (sec < 3) return '(방금)'
