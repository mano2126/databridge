            <!-- 본부장님 본질: 안 쓰는 시나리오를 최근 이력에서 제거       -->
            <!-- 효과: 자주 쓰는 시나리오만 정리되어 가독성 ↑              -->
            <!-- ════════════════════════════════════════════════════════ -->
            <button v-if="hasRecentUsage(sc.id)"
                    class="ms-list-delete"
                    @click.stop="deleteScenarioHistory(sc.id, sc.name)"
                    :title="`'${sc.name}' 을 최근 사용 이력에서 제거`">
