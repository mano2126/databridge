            </span>
          </div>
        </div>
      </div>

      <!-- ════ 우측: 전체 리스트 ════ -->
      <div class="ms-list-section">
        <div class="ms-section-title">
          <span class="ms-section-icon">📚</span>
          <span>모든 시나리오</span>
