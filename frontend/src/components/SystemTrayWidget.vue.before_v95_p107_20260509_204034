<template>
  <!-- v95_p106: 우측 하단 floating 시스템 트레이 위젯 -->
  <div v-if="visible" class="db-tray" :class="{ 'has-popover': showPopover }">
    <!-- Popover -->
    <transition name="fade-up">
      <div v-if="showPopover" class="db-popover" @click.stop>
        <div class="pop-header">
          DataBridge 엔진 상태
          <span class="pop-refresh" @click="fetchStatus" title="지금 갱신">⟳</span>
        </div>
        <div class="pop-row" @click="goAdminProcess">
          <span class="pop-dot" :class="frontendDotClass"></span>
          <span class="pop-name" :class="{ off: !frontendOn }">Frontend</span>
          <span class="pop-meta mono">
            <template v-if="frontendOn">:{{ frontendPort }} {{ frontendModeKor }}</template>
            <template v-else>중지됨</template>
          </span>
        </div>
        <div class="pop-row" @click="goAdminProcess">
          <span class="pop-dot" :class="backendDotClass"></span>
          <span class="pop-name" :class="{ off: !backendOn }">Backend</span>
          <span class="pop-meta mono">
            <template v-if="backendOn">:8000 {{ backendModeKor }}</template>
            <template v-else>중지됨</template>
          </span>
        </div>
        <div class="pop-footer">
          <span v-if="!supervisorOn" class="warn">Supervisor 응답 없음</span>
          <span v-else class="muted">관리자 콘솔에서 제어</span>
        </div>
      </div>
    </transition>

    <!-- Tray icon button -->
    <button class="db-icon" @click.stop="togglePopover" :title="iconTitle">
      <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke-width="1.6">
        <!-- Frontend curve (top) -->
        <path d="M4 11 Q16 3 28 11" :stroke="frontendStroke"
              stroke-linecap="round"
              :stroke-dasharray="frontendOn ? '' : '2 2'"/>
        <!-- Backend curve (bottom) -->
        <path d="M4 21 Q16 29 28 21" :stroke="backendStroke"
              stroke-linecap="round"
              :stroke-dasharray="backendOn ? '' : '2 2'"/>
        <!-- System boundary (sides) -->
        <line x1="4" y1="11" x2="4" y2="21" :stroke="boundaryStroke"
              stroke-linecap="round"
              :stroke-dasharray="bothOn ? '' : '2 2'"/>
        <line x1="28" y1="11" x2="28" y2="21" :stroke="boundaryStroke"
              stroke-linecap="round"
              :stroke-dasharray="bothOn ? '' : '2 2'"/>
        <!-- Data bridge (3 nodes) -->
        <circle cx="10" cy="16" r="2" :fill="frontendOn ? '#6366f1' : '#cbd5e1'"/>
        <circle cx="16" cy="16" r="2" :fill="bothOn ? '#a855f7' : '#cbd5e1'"/>
        <circle cx="22" cy="16" r="2" :fill="backendOn ? '#22c55e' : '#cbd5e1'"/>
      </svg>
      <span class="status-pip" :class="pipClass"></span>
    </button>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, onUnmounted } from 'vue'
import { useRoute, useRouter } from 'vue-router'

const route = useRoute()
const router = useRouter()

const status = ref(null)
const showPopover = ref(false)
let pollTimer = null

// Login 페이지에서는 숨김
const visible = computed(() => {
  const p = route?.path || ''
  if (p.startsWith('/login')) return false
  return true
})

// 상태 평탄화
const supervisorOn = computed(() => !!status.value?.supervisor_running)
const backendOn = computed(() => !!status.value?.running)
const frontendOn = computed(() => !!status.value?.frontend?.running)
const bothOn = computed(() => backendOn.value && frontendOn.value)
const frontendPort = computed(() => status.value?.frontend?.port || 3000)

const backendModeKor = computed(() => {
  const m = status.value?.mode
  return ({safe:'SAFE', multiprocess:'MP', thread:'TH'})[m] || (m || '')
})
const frontendModeKor = computed(() => {
  const m = status.value?.frontend?.mode
  return ({auto:'AUTO', dev:'DEV', release:'REL'})[m] || (m || '')
})

// 색상
const frontendStroke = computed(() => frontendOn.value ? '#6366f1' : '#cbd5e1')
const backendStroke = computed(() => backendOn.value ? '#22c55e' : '#cbd5e1')
const boundaryStroke = computed(() => bothOn.value ? '#94a3b8' : '#cbd5e1')

// 우상단 점 (3 상태)
const pipClass = computed(() => {
  if (!supervisorOn.value) return 'pip-off'
  if (bothOn.value) return 'pip-on'
  if (backendOn.value || frontendOn.value) return 'pip-warn'
  return 'pip-off'
})
const frontendDotClass = computed(() => frontendOn.value ? 'd-on' : 'd-off')
const backendDotClass = computed(() => backendOn.value ? 'd-on' : 'd-off')

const iconTitle = computed(() => {
  if (!supervisorOn.value) return 'Supervisor 응답 없음 — 클릭하여 상세 확인'
  if (bothOn.value) return 'DataBridge 엔진 정상 (Backend + Frontend ON)'
  if (backendOn.value) return 'Frontend 중지됨'
  if (frontendOn.value) return 'Backend 중지됨'
  return '엔진 모두 중지됨'
})

// 액션
function togglePopover() {
  showPopover.value = !showPopover.value
  if (showPopover.value) fetchStatus()
}
function closePopover() { showPopover.value = false }
function goAdminProcess() {
  closePopover()
  // 새창으로 관리자 프로세스 페이지
  window.open('/admin/console/process', 'admin-process',
    'width=1100,height=700,scrollbars=yes,resizable=yes')
}

async function fetchStatus() {
  try {
    const r = await fetch('/api/v1/process/status', { credentials: 'include' })
    if (r.ok) {
      status.value = await r.json()
    } else {
      status.value = { supervisor_running: false, running: false, frontend: { running: false } }
    }
  } catch (e) {
    status.value = { supervisor_running: false, running: false, frontend: { running: false } }
  }
}

function onClickOutside(e) {
  if (!showPopover.value) return
  // popover 또는 트레이 아이콘 클릭이 아니면 닫기
  const tray = document.querySelector('.db-tray')
  if (tray && !tray.contains(e.target)) closePopover()
}

onMounted(() => {
  fetchStatus()
  pollTimer = setInterval(fetchStatus, 5000)
  document.addEventListener('click', onClickOutside)
})
onUnmounted(() => {
  if (pollTimer) clearInterval(pollTimer)
  document.removeEventListener('click', onClickOutside)
})
</script>

