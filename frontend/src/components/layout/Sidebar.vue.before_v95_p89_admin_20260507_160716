  const set = new Set()
  if (jobs.runningJobs?.length > 0) {
    set.add('/monitor')
    set.add('/jobs/monitor')
    set.add('/jobs')
  }
  if (jobs.jobs?.some(j => j.status === 'paused')) {
    set.add('/jobs/monitor')
    set.add('/jobs')
  }
  if (jobs.pendingSchedules > 0) {
    set.add('/schedules')
  }
