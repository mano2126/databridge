// ── 메뉴 순서 드래그&드롭 ────────────────────────────────────────
const MENU_ORDER_KEY = 'sidebar_menu_order'
const MENU_ITEM_ORDER_KEY = 'sidebar_item_order'

// 섹션 순서 저장/복원
const _loadOrder = (key, defaults) => {
  try {
    const saved = JSON.parse(localStorage.getItem(key) || 'null')
    if (Array.isArray(saved) && saved.length === defaults.length) return saved
  } catch {}
  return defaults
}
const _saveOrder = (key, val) => { try { localStorage.setItem(key, JSON.stringify(val)) } catch {} }

// 드래그 상태
const dragSec   = ref(null)  // 드래그 중인 섹션 label
const dragItem  = ref(null)  // 드래그 중인 아이템 {sec, idx}
const dragOver  = ref(null)  // 현재 hover 섹션 label
const dragOverItem = ref(null)  // hover 아이템 {sec, idx}
const editMode  = ref(false) // 편집 모드 토글

// 스케줄 카운트 30초마다 갱신
import { onMounted, onUnmounted } from 'vue'
let _schedTimer = null
onMounted(() => {
  jobs.fetchScheduleCount()
  _schedTimer = setInterval(() => jobs.fetchScheduleCount(), 30000)
})
onUnmounted(() => clearInterval(_schedTimer))

const BASE_MENU = computed(() => [

  // ① 연결·스키마 — 이관 전 준비
  { label: '연결·스키마', items: [
    { to: '/connector',          label: '연결 관리',        icon: ICONS.connector },
    { to: '/connector/profiles', label: '저장된 프로파일',  sub: true },
    { to: '/connector/ssh',      label: 'SSH 터널링',       sub: true },
    { to: '/schema',             label: '스키마 탐색기',    icon: ICONS.schema },
    { to: '/schema/tables',      label: '테이블·컬럼 탐색', sub: true },
    { to: '/object-explorer',    label: '오브젝트 탐색기',  sub: true },
    { to: '/schema/diff',        label: '스키마 Diff',      sub: true },
    { to: '/schema/deps',        label: '의존성 맵',        sub: true },
    { to: '/mapping',            label: '타입 매핑',        sub: true },
    { to: '/mapping/objects',    label: '오브젝트 매핑',    sub: true },
  ]},

  // ② 전환 — 이관 실행 (Job · 스케줄 · SQL변환)
  { label: '전환', items: [
    { to: '/jobs/wizard',   label: '이관 시작',      icon: ICONS.wizard },
    { to: '/jobs',          label: 'Job 목록',        sub: true, badge: running.value || null, bdgType: 'y' },
    { to: '/cdc',           label: '증가분 처리',    sub: true },
    { to: '/schedules',     label: '스케줄 관리',     sub: true, badge: scheduleCount.value, bdgType: 'b' },
    { to: '/sql-converter', label: 'SQL 변환기',      sub: true },
  ]},

  // ③ 모니터링 — 실시간 현황 추적
  { label: '모니터링', items: [
    { to: '/dashboard',    label: '대시보드',          icon: ICONS.dashboard, badge: 'Live', bdgType: 'g' },
    { to: '/monitor',      label: '실시간 모니터',     sub: true, badge: running.value ? 'LIVE' : null, bdgType: 'g' },
    { to: '/jobs/monitor', label: '이관 작업 모니터',  sub: true, badge: running.value || null, bdgType: 'y' },
    { to: '/report',       label: '실행 리포트',       sub: true },
  ]},

  // ④ 점검 — 품질 검증 · 대사
  { label: '점검', items: [
    { to: '/validate',         label: '검증 & 대사',          icon: ICONS.validate },
    { to: '/validate/tables',  label: '테이블·오브젝트 검증',  sub: true },
    { to: '/sql-verify',       label: '쿼리 검증',             sub: true },
  ]},

  // ⑤ 관리자 — admin 역할만 표시 (hasRole('admin') 이면 true)
  ...(authStore.hasRole && authStore.hasRole('admin') ? [
    { label: '관리자', items: [
      { to: '/admin/users',   label: '사용자 관리',  icon: ICONS.connector },
      { to: '/admin/audit',   label: '감사 로그',    sub: true },
      { to: '/admin/license', label: '라이선스 관리', sub: true },
      // v59: 변환 KB 대시보드 — 페이지는 이미 있었으나 메뉴/라우터 누락이었음
      { to: '/admin/kb/conversion', label: '변환 KB 대시보드', sub: true },
    ]},
  ] : []),

])

// 섹션 순서 (label 배열) — localStorage에서 복원
const defaultSecOrder = computed(() => BASE_MENU.value.map(s => s.label))
const sectionOrder = ref([])
watch(defaultSecOrder, (defs) => {
  sectionOrder.value = _loadOrder(MENU_ORDER_KEY, defs)
}, { immediate: true })

// 아이템 순서 (섹션별 to 배열) — localStorage에서 복원
const itemOrders = ref({})
watch(BASE_MENU, (bm) => {
  const saved = (() => { try { return JSON.parse(localStorage.getItem(MENU_ITEM_ORDER_KEY) || '{}') } catch { return {} } })()
  const result = {}
  bm.forEach(sec => {
    const defaults = sec.items.map(i => i.to || i.label)
    if (Array.isArray(saved[sec.label]) && saved[sec.label].length === defaults.length) {
      result[sec.label] = saved[sec.label]
    } else {
      result[sec.label] = defaults
    }
  })
  itemOrders.value = result
}, { immediate: true })

// 최종 렌더링용 메뉴 (순서 적용)
const menu = computed(() => {
  const bm = BASE_MENU.value
  const secMap = Object.fromEntries(bm.map(s => [s.label, s]))
  return sectionOrder.value
    .map(label => {
      const sec = secMap[label]
      if (!sec) return null
      const order = itemOrders.value[label]
      if (!order) return sec
      const itemMap = Object.fromEntries(sec.items.map(i => [i.to || i.label, i]))
      return { ...sec, items: order.map(k => itemMap[k]).filter(Boolean) }
    })
    .filter(Boolean)
})

// ── 섹션 드래그 핸들러 ────────────────────────────────────────────
function onSecDragStart(e, label) {
  dragSec.value = label
  e.dataTransfer.effectAllowed = 'move'
}
function onSecDragOver(e, label) {
  e.preventDefault()
  e.dataTransfer.dropEffect = 'move'
  dragOver.value = label
}
function onSecDrop(e, targetLabel) {
  e.preventDefault()
  if (!dragSec.value || dragSec.value === targetLabel) { dragSec.value = null; dragOver.value = null; return }
  const arr = [...sectionOrder.value]
  const fi = arr.indexOf(dragSec.value)
  const ti = arr.indexOf(targetLabel)
  if (fi < 0 || ti < 0) return
  arr.splice(fi, 1)
  arr.splice(ti, 0, dragSec.value)
  sectionOrder.value = arr
  _saveOrder(MENU_ORDER_KEY, arr)
  dragSec.value = null; dragOver.value = null
}
function onSecDragEnd() { dragSec.value = null; dragOver.value = null }

// ── 아이템 드래그 핸들러 ─────────────────────────────────────────
function onItemDragStart(e, secLabel, itemKey) {
  dragItem.value = { sec: secLabel, key: itemKey }
  e.dataTransfer.effectAllowed = 'move'
  e.stopPropagation()
}
function onItemDragOver(e, secLabel, itemKey) {
  e.preventDefault(); e.stopPropagation()
  e.dataTransfer.dropEffect = 'move'
  dragOverItem.value = { sec: secLabel, key: itemKey }
}
function onItemDrop(e, secLabel, itemKey) {
  e.preventDefault(); e.stopPropagation()
  if (!dragItem.value) return
  if (dragItem.value.sec !== secLabel) return  // 섹션 간 이동 미지원
  if (dragItem.value.key === itemKey) { dragItem.value = null; dragOverItem.value = null; return }
  const arr = [...(itemOrders.value[secLabel] || [])]
  const fi = arr.indexOf(dragItem.value.key)
  const ti = arr.indexOf(itemKey)
  if (fi < 0 || ti < 0) return
  arr.splice(fi, 1); arr.splice(ti, 0, dragItem.value.key)
  itemOrders.value = { ...itemOrders.value, [secLabel]: arr }
  const allOrders = {}
  Object.entries(itemOrders.value).forEach(([k, v]) => { allOrders[k] = v })
  _saveOrder(MENU_ITEM_ORDER_KEY, allOrders)
  dragItem.value = null; dragOverItem.value = null
}
function onItemDragEnd() { dragItem.value = null; dragOverItem.value = null }

// ── 순서 초기화 ───────────────────────────────────────────────────
function resetOrder() {
  localStorage.removeItem(MENU_ORDER_KEY)
  localStorage.removeItem(MENU_ITEM_ORDER_KEY)
  localStorage.removeItem('sidebar_open_sections')
  sectionOrder.value = defaultSecOrder.value
  itemOrders.value = Object.fromEntries(
    BASE_MENU.value.map(s => [s.label, s.items.map(i => i.to || i.label)])
  )
  editMode.value = false
}
</script>

