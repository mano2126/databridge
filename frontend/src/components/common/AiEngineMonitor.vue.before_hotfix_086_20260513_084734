            <div class="aem-bar-row">
              <span class="aem-l-sm">Processor</span>
              <div class="aem-bar">
                <div class="aem-bar-cpu" :style="{ width: m.cpu_pct + '%' }"
                     :title="`CPU ${m.cpu_pct}%`"></div>
                <div class="aem-bar-gpu" :style="{ width: m.gpu_pct + '%' }"
