      "src_hash": "209b79e44979355e",
      "src_sample_ddl": "\r\nCREATE FUNCTION [dbo].[ufnGetStock](@ProductID [int])\r\nRETURNS [int] \r\nAS \r\n-- Returns the stock level for the product. This function is used internally only\r\nBEGIN\r\n    DECLARE @ret int;\r\n    \r\n    SELECT @ret = SUM(p.[Quantity]) \r\n    FROM [Production].[ProductInventory] p \r\n    WHERE p.[ProductID] = @ProductID \r\n        AND p.[LocationID] = '6'; -- Only look at inventory in the misc storage\r\n    \r\n    IF (@ret IS NULL) \r\n        SET @ret = 0\r\n    \r\n    RETURN @ret\r\nEND;\r\n",
      "tgt_sample_ddl": "DROP FUNCTION IF EXISTS dbo_ufnGetStock;\nCREATE FUNCTION dbo_ufnGetStock(p_ProductID INT) RETURNS INT DETERMINISTIC READS SQL DATA BEGIN DECLARE v_ret INT; SELECT SUM(p.Quantity) INTO v_ret FROM Production_ProductInventory p WHERE p.ProductID = p_ProductID AND p.LocationID = '6'; IF (v_ret IS NULL) THEN SET v_ret = 0; END IF; RETURN v_ret; END;",
