    {
      "id": "kb_9f0f4f0ced9a3514",
      "src_db": "mssql",
      "tgt_db": "mysql",
      "obj_type": "TRIGGER",
      "obj_name_sample": "iduSalesOrderDetail",
      "src_pattern_keywords": [
