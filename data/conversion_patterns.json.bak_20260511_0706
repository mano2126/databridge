      "src_pattern_keywords": [],
      "src_hash": "a377686a901823fa",
      "src_sample_ddl": "\r\n\r\n\r\nCREATE FUNCTION [dbo].[ufnGetProductDealerPrice](@ProductID [int], @OrderDate [datetime])\r\nRETURNS [money] \r\nAS \r\n-- Returns the dealer price for the product on a specific date.\r\nBEGIN\r\n    DECLARE @DealerPrice money;\r\n    DECLARE @DealerDiscount money;\r\n\r\n    SET @DealerDiscount = 0.60  -- 60% of list price\r\n\r\n    SELECT @DealerPrice = plph.[ListPrice] * @DealerDiscount \r\n    FROM [Production].[Product] p \r\n        INNER JOIN [Production].[ProductListPriceHistory] plph \r\n        ON p.[ProductID] = plph.[ProductID] \r\n            AND p.[ProductID] = @ProductID \r\n            AND @OrderDate BETWEEN plph.[StartDate] AND COALESCE(plph.[EndDate], CONVERT(datetime, '99991231', 112)); -- Make sure we get all the prices!\r\n\r\n    RETURN @DealerPrice;\r\nEND;\r\n",
      "tgt_sample_ddl": "DROP FUNCTION IF EXISTS dbo_ufnGetProductDealerPrice;\nCREATE FUNCTION dbo_ufnGetProductDealerPrice(p_ProductID INT, p_OrderDate DATETIME) RETURNS DECIMAL(19,4) DETERMINISTIC READS SQL DATA BEGIN DECLARE v_DealerPrice DECIMAL(19,4); DECLARE v_DealerDiscount DECIMAL(19,4); SET v_DealerDiscount = 0.60; SELECT p_plph_ListPrice * v_DealerDiscount INTO v_DealerPrice FROM Production_Product p INNER JOIN Production_ProductListPriceHistory p_plph ON p.ProductID = p_plph.ProductID AND p.ProductID = p_ProductID AND p_OrderDate BETWEEN p_plph.StartDate AND COALESCE(p_plph.EndDate, STR_TO_DATE('99991231', '%Y%m%d')); RETURN v_DealerPrice; END;",
      "source": "ai_success",
      "registered_at": "2026-05-10T13:17:16",
      "use_count": 2,
      "last_used_at": "2026-05-10T15:52:38"
