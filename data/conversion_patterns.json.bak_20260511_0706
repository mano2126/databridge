      "tgt_sample_ddl": "DROP VIEW IF EXISTS Production_vProductModelInstructions;\nCREATE VIEW Production_vProductModelInstructions AS SELECT p.ProductModelID, p.Name, p.Instructions, CAST(NULL AS UNSIGNED) AS LocationID, CAST(NULL AS DECIMAL(9, 4)) AS SetupHours, CAST(NULL AS DECIMAL(9, 4)) AS MachineHours, CAST(NULL AS DECIMAL(9, 4)) AS LaborHours, CAST(NULL AS UNSIGNED) AS LotSize, CAST(NULL AS CHAR) AS Step, p.rowguid, p.ModifiedDate FROM Production_ProductModel AS p;",
