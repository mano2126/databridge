      "src_hash": "b2760db5af11a239",
      "src_sample_ddl": "\r\nCREATE FUNCTION [dbo].[ufnLeadingZeros](\r\n    @Value int\r\n) \r\nRETURNS varchar(8) \r\nWITH SCHEMABINDING \r\nAS \r\nBEGIN\r\n    DECLARE @ReturnValue varchar(8);\r\n\r\n    SET @ReturnValue = CONVERT(varchar(8), @Value);\r\n    SET @ReturnValue = REPLICATE('0', 8 - DATALENGTH(@ReturnValue)) + @ReturnValue;\r\n\r\n    RETURN (@ReturnValue);\r\nEND;\r\n",
      "tgt_sample_ddl": "DROP FUNCTION IF EXISTS dbo_ufnLeadingZeros;\nCREATE FUNCTION dbo_ufnLeadingZeros(p_Value INT) RETURNS VARCHAR(8) DETERMINISTIC READS SQL DATA BEGIN DECLARE p_ReturnValue VARCHAR(8); SET p_ReturnValue = CAST(p_Value AS CHAR); SET p_ReturnValue = LPAD(p_ReturnValue, 8, '0'); RETURN p_ReturnValue; END;",
