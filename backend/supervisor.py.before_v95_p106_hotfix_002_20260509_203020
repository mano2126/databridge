def _find_npm() -> Optional[str]:
    """npm 실행 파일 경로 자동 감지 (nvm/brew 환경 대응)."""
    candidates = [
        "/usr/local/bin/npm",
        "/opt/homebrew/bin/npm",
        os.path.expanduser("~/.nvm/versions/node/*/bin/npm"),
    ]
    import shutil
    p = shutil.which("npm")
    if p:
        return p
    for c in candidates:
        if "*" in c:
            import glob
            matches = sorted(glob.glob(c))
            if matches:
                return matches[-1]
        elif Path(c).exists():
            return c
    return None

