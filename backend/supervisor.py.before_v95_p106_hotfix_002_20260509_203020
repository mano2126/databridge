_supervisor_start_time = time.time()

@app.on_event("startup")
async def on_startup():
    global _main_loop
    _main_loop = asyncio.get_event_loop()
    try:
        SUPERVISOR_PID.write_text(str(os.getpid()))
    except Exception as e:
        log.warning("Supervisor PID 파일 기록 실패: %s", e)
    threading.Thread(target=_keepalive_monitor, daemon=True, name="keepalive").start()
    log.info("Supervisor 시작 — PID=%d, OS=%s, port=8765", os.getpid(), OS_NAME)
    log.info("API: http://127.0.0.1:8765/supervisor/...")
    log.info("Backend WS: ws://127.0.0.1:8765/supervisor/console/ws")
    log.info("Frontend WS: ws://127.0.0.1:8765/supervisor/frontend/console/ws")
    if FRONTEND_DIR:
        log.info("Frontend dir: %s", FRONTEND_DIR)
    if NPM_PATH:
        log.info("npm path: %s", NPM_PATH)

@app.on_event("shutdown")
async def on_shutdown():
    log.info("Supervisor 종료 — Backend+Frontend 함께 정리")
    if state.is_alive():
        _stop_backend(timeout=5.0)
    if state.fe_is_alive():
        _stop_frontend(timeout=5.0)
    try:
        if SUPERVISOR_PID.exists():
            SUPERVISOR_PID.unlink()
    except Exception:
        pass

def _signal_handler(signum, frame):
    log.info("Supervisor signal %d 수신 → 종료", signum)
    if state.is_alive():
        _stop_backend(timeout=5.0)
    if state.fe_is_alive():
        _stop_frontend(timeout=5.0)
    sys.exit(0)

if not IS_WINDOWS:
    signal.signal(signal.SIGTERM, _signal_handler)
    signal.signal(signal.SIGINT,  _signal_handler)

