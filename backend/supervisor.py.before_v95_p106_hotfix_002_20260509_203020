@app.get("/supervisor/console")
def get_console(tail: int = 500):
    with state.lock:
        all_lines = list(state.console_ring)
    if tail and tail > 0:
        all_lines = all_lines[-tail:]
    return {"lines": all_lines, "total": len(all_lines)}

@app.websocket("/supervisor/console/ws")
async def console_stream(ws: WebSocket):
    await ws.accept()
    state.ws_clients.add(ws)
    try:
        with state.lock:
            recent = list(state.console_ring)[-100:]
        for entry in recent:
            await ws.send_text(json.dumps(entry, ensure_ascii=False))
        while True:
            try:
                await asyncio.wait_for(ws.receive_text(), timeout=30.0)
            except asyncio.TimeoutError:
                try:
                    await ws.send_text(json.dumps({"type": "ping",
                        "ts": datetime.now().strftime("%H:%M:%S")}))
                except Exception:
                    break
    except WebSocketDisconnect:
        pass
    except Exception as e:
        log.warning("Backend WS 클라이언트 예외: %s", e)
    finally:
        state.ws_clients.discard(ws)

# ─── Frontend 라우트 ─────────────────────────────────────
@app.post("/supervisor/frontend/start")
def post_fe_start(body: FrontendStartRequest):
    return _start_frontend(body.mode)

@app.post("/supervisor/frontend/stop")
def post_fe_stop():
    return _stop_frontend()

@app.post("/supervisor/frontend/restart")
def post_fe_restart(body: FrontendRestartRequest):
    return _restart_frontend(body.mode)

@app.get("/supervisor/frontend/console")
def get_fe_console(tail: int = 500):
    with state.lock:
        all_lines = list(state.fe_console_ring)
    if tail and tail > 0:
        all_lines = all_lines[-tail:]
    return {"lines": all_lines, "total": len(all_lines)}

@app.websocket("/supervisor/frontend/console/ws")
async def fe_console_stream(ws: WebSocket):
    await ws.accept()
    state.fe_ws_clients.add(ws)
    try:
        with state.lock:
            recent = list(state.fe_console_ring)[-100:]
        for entry in recent:
            await ws.send_text(json.dumps(entry, ensure_ascii=False))
        while True:
            try:
                await asyncio.wait_for(ws.receive_text(), timeout=30.0)
            except asyncio.TimeoutError:
                try:
                    await ws.send_text(json.dumps({"type": "ping"}))
                except Exception:
                    break
    except WebSocketDisconnect:
        pass
    except Exception as e:
        log.warning("Frontend WS 클라이언트 예외: %s", e)
    finally:
        state.fe_ws_clients.discard(ws)

