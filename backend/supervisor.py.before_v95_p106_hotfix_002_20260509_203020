# ─── 상태 ────────────────────────────────────────────────
class SupervisorState:
    def __init__(self):
        # Backend
        self.process: Optional[subprocess.Popen] = None
        self.mode: str = ""
        self.started_at: Optional[float] = None
        self.console_ring: deque = deque(maxlen=CONSOLE_RING_SIZE)
        self.ws_clients: Set[WebSocket] = set()
        self.intentional_stop = False
        # Frontend
        self.fe_process: Optional[subprocess.Popen] = None
        self.fe_mode: str = ""
        self.fe_started_at: Optional[float] = None
        self.fe_console_ring: deque = deque(maxlen=CONSOLE_RING_SIZE)
        self.fe_ws_clients: Set[WebSocket] = set()
        self.fe_intentional_stop = False
        self.lock = threading.RLock()
    
    def is_alive(self) -> bool:
        with self.lock:
            return self.process is not None and self.process.poll() is None
    def get_pid(self) -> Optional[int]:
        with self.lock:
            return self.process.pid if self.is_alive() else None
    def get_uptime(self) -> Optional[float]:
        with self.lock:
            if self.started_at and self.is_alive():
                return time.time() - self.started_at
            return None
    
    def fe_is_alive(self) -> bool:
        with self.lock:
            return self.fe_process is not None and self.fe_process.poll() is None
    def fe_get_pid(self) -> Optional[int]:
        with self.lock:
            return self.fe_process.pid if self.fe_is_alive() else None
    def fe_get_uptime(self) -> Optional[float]:
        with self.lock:
            if self.fe_started_at and self.fe_is_alive():
                return time.time() - self.fe_started_at
            return None

state = SupervisorState()

# ─── 콘솔 캡처 스레드 ─────────────────────────────────────
def _console_pump(stream, prefix: str, ring: deque, ws_clients: Set[WebSocket], engine: str):
    """엔진(backend/frontend)의 stdout/stderr 를 라인 단위로 읽어 링버퍼 + WS 브로드캐스트."""
    try:
        for raw in iter(stream.readline, b""):
            try:
                line = raw.decode("utf-8", errors="replace").rstrip()
            except Exception:
                line = repr(raw)[:200]
            ts = datetime.now().strftime("%H:%M:%S")
            entry = {"ts": ts, "stream": prefix, "line": line, "engine": engine}
            with state.lock:
                ring.append(entry)
            _broadcast_to_ws(entry, ws_clients)
    except Exception as e:
        log.error("[console_pump:%s/%s] 예외: %s", engine, prefix, e)

# ─── WebSocket 브로드캐스트 ───────────────────────────────
_main_loop: Optional[asyncio.AbstractEventLoop] = None

def _broadcast_to_ws(entry: Dict, clients: Set[WebSocket]):
    if _main_loop is None or _main_loop.is_closed():
        return
    try:
        asyncio.run_coroutine_threadsafe(_async_broadcast(entry, clients), _main_loop)
    except Exception:
        pass

async def _async_broadcast(entry: Dict, clients: Set[WebSocket]):
    msg = json.dumps(entry, ensure_ascii=False)
    dead = []
    for ws in list(clients):
        try:
            await ws.send_text(msg)
        except Exception:
            dead.append(ws)
    for ws in dead:
        clients.discard(ws)

# ─── Backend 시작/종료 ───────────────────────────────────
def _build_env(mode: str) -> Dict[str, str]:
    env = os.environ.copy()
    env["DATABRIDGE_DEV_MODE"] = "1"
    if mode == "multiprocess":
        env["DATABRIDGE_CHUNK_EXPERIMENT"] = "1"
        env["DATABRIDGE_CHUNK_MODE"] = "process"
    elif mode == "thread":
        env["DATABRIDGE_CHUNK_EXPERIMENT"] = "1"
        env["DATABRIDGE_CHUNK_MODE"] = "thread"
    else:
        env.pop("DATABRIDGE_CHUNK_EXPERIMENT", None)
        env.pop("DATABRIDGE_CHUNK_MODE", None)
    env["PYTHONUNBUFFERED"] = "1"
    return env

def _start_backend(mode: str = "safe") -> Dict:
    with state.lock:
        if state.is_alive():
            return {"ok": False, "error": f"이미 실행 중 (PID={state.get_pid()})"}
        if mode not in ("safe", "multiprocess", "thread"):
            return {"ok": False, "error": f"Invalid mode: {mode}"}
        venv_python = BACKEND_DIR / "venv" / ("Scripts/python.exe" if IS_WINDOWS else "bin/python")
        if not venv_python.exists():
            return {"ok": False, "error": f"venv python 없음: {venv_python}"}
        cmd = [str(venv_python), "-m", "uvicorn", "main:app", "--port", "8000", "--host", "0.0.0.0"]
        env = _build_env(mode)
        try:
            popen_kwargs = dict(
                cmd=cmd, cwd=str(BACKEND_DIR), env=env,
                stdout=subprocess.PIPE, stderr=subprocess.PIPE, bufsize=0,
            )
            if IS_WINDOWS:
                popen_kwargs["creationflags"] = subprocess.CREATE_NEW_PROCESS_GROUP
            else:
                popen_kwargs["start_new_session"] = True
            proc = subprocess.Popen(**popen_kwargs)
            state.process = proc
            state.mode = mode
            state.started_at = time.time()
            state.intentional_stop = False
            try: PID_FILE.write_text(str(proc.pid))
            except Exception as e: log.warning("PID 파일 기록 실패: %s", e)
            threading.Thread(target=_console_pump,
                args=(proc.stdout, "stdout", state.console_ring, state.ws_clients, "backend"),
                daemon=True, name="backend-stdout").start()
            threading.Thread(target=_console_pump,
                args=(proc.stderr, "stderr", state.console_ring, state.ws_clients, "backend"),
                daemon=True, name="backend-stderr").start()
            log.info("Backend 시작 (PID=%d, mode=%s)", proc.pid, mode)
            return {"ok": True, "pid": proc.pid, "mode": mode}
        except Exception as e:
            log.exception("Backend 시작 실패")
            return {"ok": False, "error": str(e)}

def _stop_backend(timeout: float = 10.0) -> Dict:
    with state.lock:
        if not state.is_alive():
            return {"ok": True, "message": "이미 중지됨"}
        state.intentional_stop = True
        proc = state.process
        pid = proc.pid
    try:
        if IS_WINDOWS:
            proc.send_signal(signal.CTRL_BREAK_EVENT)
        else:
            try:
                os.killpg(os.getpgid(pid), signal.SIGTERM)
            except (ProcessLookupError, OSError):
                proc.terminate()
        log.info("Backend SIGTERM (PID=%d), grace %.1fs", pid, timeout)
        try:
            proc.wait(timeout=timeout)
            log.info("Backend 정상 종료 (PID=%d)", pid)
        except subprocess.TimeoutExpired:
            log.warning("Backend grace 타임아웃 → SIGKILL")
            if IS_WINDOWS:
                proc.kill()
            else:
                try: os.killpg(os.getpgid(pid), signal.SIGKILL)
                except Exception: proc.kill()
            proc.wait(timeout=3)
        with state.lock:
            state.process = None
            state.started_at = None
        try: PID_FILE.unlink()
        except Exception: pass
        return {"ok": True, "message": f"Backend 중지됨 (PID={pid})"}
    except Exception as e:
        log.exception("Backend 중지 실패")
        return {"ok": False, "error": str(e)}

def _restart_backend(mode: Optional[str] = None) -> Dict:
    with state.lock:
        target_mode = mode or state.mode or "safe"
    log.info("Backend 재시작 (mode=%s)", target_mode)
    stop_result = _stop_backend(timeout=10.0)
    if not stop_result.get("ok"):
        return stop_result
    time.sleep(1.0)
    return _start_backend(target_mode)

# ─── Frontend 시작/종료 ──────────────────────────────────
def _start_frontend(mode: str = "auto") -> Dict:
    """Frontend 시작.
    mode:
      auto    — frontend/dist 존재하면 release, 없으면 dev
      dev     — npm run dev (Vite HMR)
      release — npx serve -s dist -l 3000
    """
    with state.lock:
        if state.fe_is_alive():
            return {"ok": False, "error": f"Frontend 이미 실행 중 (PID={state.fe_get_pid()})"}
        if FRONTEND_DIR is None:
            return {"ok": False, "error": "frontend 디렉토리 못 찾음"}
        if mode == "auto":
            if FRONTEND_DIST and FRONTEND_DIST.exists() and any(FRONTEND_DIST.iterdir()):
                mode = "release"
            else:
                mode = "dev"
        if mode not in ("dev", "release"):
            return {"ok": False, "error": f"Invalid frontend mode: {mode}"}
        cmd = None
        if mode == "dev":
            if not NPM_PATH:
                return {"ok": False, "error": "npm 못 찾음 (PATH 확인 필요)"}
            cmd = [NPM_PATH, "run", "dev"]
        elif mode == "release":
            if not (FRONTEND_DIST and FRONTEND_DIST.exists()):
                return {"ok": False, "error": f"빌드 결과 없음: {FRONTEND_DIST} — 'npm run build' 먼저 실행"}
            if NPX_PATH:
                cmd = [NPX_PATH, "-y", "serve", "-s", str(FRONTEND_DIST), "-l", str(FRONTEND_PORT)]
            else:
                python_exe = sys.executable
                cmd = [python_exe, "-m", "http.server", str(FRONTEND_PORT),
                       "--directory", str(FRONTEND_DIST)]
        env = os.environ.copy()
        env["PYTHONUNBUFFERED"] = "1"
        env["FORCE_COLOR"] = "0"
        env["NO_COLOR"] = "1"
        if NPM_PATH:
            npm_bin = str(Path(NPM_PATH).parent)
            existing_path = env.get("PATH", "")
            if npm_bin not in existing_path:
                env["PATH"] = npm_bin + os.pathsep + existing_path
        try:
            popen_kwargs = dict(
                cmd=cmd, cwd=str(FRONTEND_DIR), env=env,
                stdout=subprocess.PIPE, stderr=subprocess.PIPE, bufsize=0,
            )
            if IS_WINDOWS:
                popen_kwargs["creationflags"] = subprocess.CREATE_NEW_PROCESS_GROUP
            else:
                popen_kwargs["start_new_session"] = True
            proc = subprocess.Popen(**popen_kwargs)
            state.fe_process = proc
            state.fe_mode = mode
            state.fe_started_at = time.time()
            state.fe_intentional_stop = False
            threading.Thread(target=_console_pump,
                args=(proc.stdout, "stdout", state.fe_console_ring, state.fe_ws_clients, "frontend"),
                daemon=True, name="frontend-stdout").start()
            threading.Thread(target=_console_pump,
                args=(proc.stderr, "stderr", state.fe_console_ring, state.fe_ws_clients, "frontend"),
                daemon=True, name="frontend-stderr").start()
            log.info("Frontend 시작 (PID=%d, mode=%s, cmd=%s)", proc.pid, mode, " ".join(cmd[:3]))
            return {"ok": True, "pid": proc.pid, "mode": mode, "port": FRONTEND_PORT}
        except Exception as e:
            log.exception("Frontend 시작 실패")
            return {"ok": False, "error": str(e)}

def _stop_frontend(timeout: float = 10.0) -> Dict:
    with state.lock:
        if not state.fe_is_alive():
            return {"ok": True, "message": "Frontend 이미 중지됨"}
        state.fe_intentional_stop = True
        proc = state.fe_process
        pid = proc.pid
    try:
        if IS_WINDOWS:
            proc.send_signal(signal.CTRL_BREAK_EVENT)
        else:
            try:
                os.killpg(os.getpgid(pid), signal.SIGTERM)
            except (ProcessLookupError, OSError):
                proc.terminate()
        log.info("Frontend SIGTERM (PID=%d), grace %.1fs", pid, timeout)
        try:
            proc.wait(timeout=timeout)
            log.info("Frontend 정상 종료 (PID=%d)", pid)
        except subprocess.TimeoutExpired:
            log.warning("Frontend grace 타임아웃 → SIGKILL")
            if IS_WINDOWS:
                proc.kill()
            else:
                try: os.killpg(os.getpgid(pid), signal.SIGKILL)
                except Exception: proc.kill()
            proc.wait(timeout=3)
        with state.lock:
            state.fe_process = None
            state.fe_started_at = None
        return {"ok": True, "message": f"Frontend 중지됨 (PID={pid})"}
    except Exception as e:
        log.exception("Frontend 중지 실패")
        return {"ok": False, "error": str(e)}

def _restart_frontend(mode: Optional[str] = None) -> Dict:
    with state.lock:
        target_mode = mode or state.fe_mode or "auto"
    log.info("Frontend 재시작 (mode=%s)", target_mode)
    stop_result = _stop_frontend(timeout=10.0)
    if not stop_result.get("ok"):
        return stop_result
    time.sleep(1.0)
    return _start_frontend(target_mode)

# ─── KeepAlive 모니터 (자동 재시작) ──────────────────────
def _keepalive_monitor():
    while True:
        try:
            time.sleep(1.0)
            # Backend 감시
            with state.lock:
                if state.process is not None and not state.intentional_stop:
                    if state.process.poll() is not None:
                        exit_code = state.process.returncode
                        crashed_mode = state.mode
                        log.warning("Backend 비정상 종료 (exit=%s, mode=%s) → 자동 재시작",
                                    exit_code, crashed_mode)
                        state.process = None
                        state.started_at = None
            with state.lock:
                should_restart_be = (state.process is None and not state.intentional_stop
                                     and state.mode != "")
                target_be_mode = state.mode or "safe"
            if should_restart_be:
                time.sleep(1.0)
                result = _start_backend(target_be_mode)
                log.info("Backend 자동 재시작: %s", result)
            # Frontend 감시
            with state.lock:
                if state.fe_process is not None and not state.fe_intentional_stop:
                    if state.fe_process.poll() is not None:
                        exit_code = state.fe_process.returncode
                        crashed_mode = state.fe_mode
                        log.warning("Frontend 비정상 종료 (exit=%s, mode=%s) → 자동 재시작",
                                    exit_code, crashed_mode)
                        state.fe_process = None
                        state.fe_started_at = None
            with state.lock:
                should_restart_fe = (state.fe_process is None and not state.fe_intentional_stop
                                     and state.fe_mode != "")
                target_fe_mode = state.fe_mode or "auto"
            if should_restart_fe:
                time.sleep(1.0)
                result = _start_frontend(target_fe_mode)
                log.info("Frontend 자동 재시작: %s", result)
        except Exception as e:
            log.error("[keepalive] 예외: %s", e)
            time.sleep(2.0)

