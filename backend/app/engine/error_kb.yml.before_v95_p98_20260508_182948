  # ─── 카테고리 2: MSSQL 전용 타입 매핑 ────────────────────────
  MSSQL_MONEY_TYPE_004:
    error_code: 1064
    category: TYPE
    applies_to: [FUNCTION, PROCEDURE, TRIGGER]
    regex: "(?i)\\b(money|smallmoney)\\b"
    cause: "MSSQL MONEY/SMALLMONEY 는 MySQL 미지원"
    fix_type: prompt_injection
    fix_prompt: |
