    applies_to: [PROCEDURE, FUNCTION]
    regex: "1064.*near.*UNION\\s+ALL\\s+SELECT.*\\."
    cause: "MSSQL 의 ;WITH cte AS (...UNION ALL...) → MySQL 의 WITH RECURSIVE 변환 누락"
