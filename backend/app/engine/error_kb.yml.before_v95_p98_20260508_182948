        ERROR_SEVERITY()
        ERROR_STATE()
        ERROR_LINE()
        ERROR_PROCEDURE()
      
      ✅ MySQL 등가 (GET DIAGNOSTICS):
        DECLARE @errno INT;
        DECLARE @errmsg VARCHAR(255);
        DECLARE @sqlstate VARCHAR(5);
        DECLARE EXIT HANDLER FOR SQLEXCEPTION
        BEGIN
            GET DIAGNOSTICS CONDITION 1
