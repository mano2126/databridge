    seed_source: "AdventureWorks — ufnGetProductDealerPrice 등 3건"

  # ─── 카테고리 3: FUNCTION AS BEGIN ───────────────────────────
  FUNC_AS_BEGIN_005:
    error_code: 1064
    category: FUNCTION
    applies_to: [FUNCTION]
    regex: "RETURNS\\s+\\w+(\\([^)]*\\))?\\s*\\n?\\s*AS\\s*\\n?\\s*BEGIN"
    cause: "MSSQL 의 AS BEGIN 패턴 — MySQL 은 DETERMINISTIC BEGIN"
    fix_type: prompt_injection
    fix_prompt: |
      [FUNCTION 전용] AS BEGIN 패턴 금지 (MSSQL 잔재).

      ❌ 잘못된 예 (1064 또는 1418):
        CREATE FUNCTION fn(...) RETURNS INT
        AS                       ← AS 는 MSSQL 잔재
        BEGIN ... END

      ✅ 올바른 예:
        CREATE FUNCTION fn(...) RETURNS INT
        DETERMINISTIC            ← MySQL 필수 (또는 NOT DETERMINISTIC)
        BEGIN ... END

      DETERMINISTIC 결정 기준:
        - 같은 입력 → 같은 결과 → DETERMINISTIC
        - 랜덤/시간/외부 조회 → NOT DETERMINISTIC
        - 단순 계산/조회 함수는 대부분 DETERMINISTIC
    seed_source: "AdventureWorks — ufnGetDocumentStatusText 등 11건"

