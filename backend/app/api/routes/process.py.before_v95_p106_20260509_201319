"""
app/api/routes/process.py — v95_p106 (2026-05-09 본부장님 비전)

Supervisor (port 8765) 게이트웨이 — Backend + Frontend 통합 관리.
프론트엔드 UI 는 이 모듈을 거쳐 Supervisor 와 통신.

Backend API:
  GET    /api/v1/process/status                  — Backend + Frontend 통합 상태
  POST   /api/v1/process/start                   — Backend 시작 (mode: safe|multiprocess|thread)
  POST   /api/v1/process/stop                    — Backend 정상 종료
  POST   /api/v1/process/restart                 — Backend 재시작
  GET    /api/v1/process/console/ws-info         — Backend 콘솔 WS 접속 정보
  GET    /api/v1/process/console                 — Backend 콘솔 히스토리

Frontend API (v95_p106):
  GET    /api/v1/process/frontend/status         — Frontend 상태
  POST   /api/v1/process/frontend/start          — Frontend 시작 (mode: auto|dev|release)
  POST   /api/v1/process/frontend/stop           — Frontend 정상 종료
  POST   /api/v1/process/frontend/restart        — Frontend 재시작
  GET    /api/v1/process/frontend/console/ws-info — Frontend 콘솔 WS 접속 정보
  GET    /api/v1/process/frontend/console        — Frontend 콘솔 히스토리

권한:
  status  → require_viewer
  start/stop/restart → require_admin

Supervisor 가 죽어 있으면 status 는 모두 False 반환 (UI 가 "Supervisor 중지됨" 표시).
"""
from __future__ import annotations
import os
import logging
import platform
from typing import Optional
from fastapi import APIRouter, Depends, HTTPException
from pydantic import BaseModel
import httpx

from app.core.auth_deps import require_admin, require_viewer

router = APIRouter()
_log = logging.getLogger("databridge.process")

# Supervisor endpoint (별도 데몬, 포트 8765)
SUPERVISOR_BASE = os.environ.get("DATABRIDGE_SUPERVISOR_URL", "http://127.0.0.1:8765")
SUPERVISOR_TIMEOUT = 5.0   # 초

# ─── 헬퍼 ────────────────────────────────────────────────
async def _supervisor_get(path: str, timeout: float = SUPERVISOR_TIMEOUT) -> dict:
    """Supervisor 에 GET 요청. Supervisor 죽어 있으면 예외 (호출 측에서 처리)."""
    async with httpx.AsyncClient(timeout=timeout) as client:
        r = await client.get(f"{SUPERVISOR_BASE}{path}")
        r.raise_for_status()
        return r.json()

async def _supervisor_post(path: str, body: dict | None = None,
                            timeout: float = SUPERVISOR_TIMEOUT) -> dict:
    """Supervisor 에 POST 요청."""
    async with httpx.AsyncClient(timeout=timeout) as client:
        r = await client.post(f"{SUPERVISOR_BASE}{path}", json=body or {})
        r.raise_for_status()
        return r.json()

# ─── API 모델 ────────────────────────────────────────────
class FrontendStatus(BaseModel):
    running: bool = False
    pid: Optional[int] = None
    mode: str = ""
    port: int = 3000
    started_at: Optional[float] = None
    uptime_seconds: Optional[float] = None
    intentional_stop: bool = False
    console_lines: int = 0
    frontend_dir: str = ""
    dist_exists: bool = False
    npm_path: str = ""

class ProcessStatusResponse(BaseModel):
    # Supervisor 자체 상태
    supervisor_running: bool = False
    supervisor_pid: Optional[int] = None
    supervisor_url: str = SUPERVISOR_BASE
    # Backend
    running: bool = False
    pid: Optional[int] = None
    mode: str = ""
    started_at: Optional[float] = None
    uptime_seconds: Optional[float] = None
    intentional_stop: bool = False
    console_lines: int = 0
    # Frontend (nested)
    frontend: FrontendStatus = FrontendStatus()
    # 공통
    platform: str = ""
    self_pid: int = 0

class ProcessStartRequest(BaseModel):
    mode: str = "safe"            # safe | multiprocess | thread

class FrontendStartRequest(BaseModel):
    mode: str = "auto"            # auto | dev | release

class ProcessActionResponse(BaseModel):
    ok: bool
    message: str
    pid: Optional[int] = None

class WsInfoResponse(BaseModel):
    ws_url: str
    enabled: bool
    note: str = ""

# ════════════════════════════════════════════════════════════════
# Backend 라우트
# ════════════════════════════════════════════════════════════════

@router.get("/status", response_model=ProcessStatusResponse)
async def process_status(_=Depends(require_viewer)):
    """Backend + Frontend 통합 상태 (Supervisor 게이트웨이)."""
    self_pid = os.getpid()
    try:
        data = await _supervisor_get("/supervisor/status", timeout=2.0)
        fe = data.get("frontend", {}) or {}
        return ProcessStatusResponse(
            supervisor_running=True,
            supervisor_pid=data.get("supervisor_pid"),
            running=bool(data.get("running")),
            pid=data.get("pid"),
            mode=data.get("mode") or "",
            started_at=data.get("started_at"),
            uptime_seconds=data.get("uptime_seconds"),
            intentional_stop=bool(data.get("intentional_stop")),
            console_lines=int(data.get("console_lines") or 0),
            frontend=FrontendStatus(
                running=bool(fe.get("running")),
                pid=fe.get("pid"),
                mode=fe.get("mode") or "",
                port=int(fe.get("port") or 3000),
                started_at=fe.get("started_at"),
                uptime_seconds=fe.get("uptime_seconds"),
                intentional_stop=bool(fe.get("intentional_stop")),
                console_lines=int(fe.get("console_lines") or 0),
                frontend_dir=fe.get("frontend_dir") or "",
                dist_exists=bool(fe.get("dist_exists")),
                npm_path=fe.get("npm_path") or "",
            ),
            platform=data.get("platform") or platform.system(),
            self_pid=self_pid,
        )
    except (httpx.RequestError, httpx.HTTPStatusError) as e:
        _log.warning("[process] Supervisor 응답 없음: %s", e)
        # Supervisor 죽어 있음 — 기본값 반환
        return ProcessStatusResponse(
            supervisor_running=False,
            platform=platform.system(),
            self_pid=self_pid,
        )

@router.post("/start", response_model=ProcessActionResponse)
async def process_start(body: ProcessStartRequest, _=Depends(require_admin)):
    """Backend 시작 (Supervisor 통해)."""
    if body.mode not in ("safe", "multiprocess", "thread"):
        raise HTTPException(400, f"Invalid mode: {body.mode}")
    try:
        data = await _supervisor_post("/supervisor/start", {"mode": body.mode}, timeout=15.0)
        return ProcessActionResponse(
            ok=bool(data.get("ok")),
            message=data.get("error") or data.get("message") or f"Backend 시작됨 (mode={body.mode})",
            pid=data.get("pid"),
        )
    except httpx.RequestError as e:
        raise HTTPException(503, f"Supervisor 응답 없음 (port 8765): {e}")

@router.post("/stop", response_model=ProcessActionResponse)
async def process_stop(_=Depends(require_admin)):
    """Backend 정상 종료 (Supervisor 통해)."""
    try:
        data = await _supervisor_post("/supervisor/stop", {}, timeout=15.0)
        return ProcessActionResponse(
            ok=bool(data.get("ok", True)),
            message=data.get("error") or data.get("message") or "Backend 중지됨",
            pid=data.get("pid"),
        )
    except httpx.RequestError as e:
        raise HTTPException(503, f"Supervisor 응답 없음: {e}")

