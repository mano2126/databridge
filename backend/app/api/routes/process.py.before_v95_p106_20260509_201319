@router.get("/console/ws-info", response_model=WsInfoResponse)
async def backend_ws_info(_=Depends(require_viewer)):
    """Backend 콘솔 WebSocket 접속 정보."""
    return WsInfoResponse(
        ws_url=SUPERVISOR_BASE.replace("http://", "ws://").replace("https://", "wss://")
               + "/supervisor/console/ws",
        enabled=True,
        note="Backend stdout/stderr 실시간 스트림"
    )

@router.get("/console")
async def backend_console_history(tail: int = 500, _=Depends(require_viewer)):
    """Backend 콘솔 히스토리."""
    try:
        return await _supervisor_get(f"/supervisor/console?tail={tail}", timeout=3.0)
    except (httpx.RequestError, httpx.HTTPStatusError):
        return {"lines": [], "total": 0}

