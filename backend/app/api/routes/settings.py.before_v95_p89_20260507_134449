_usage_store = Store("claude_usage")

@router.get("/claude-usage")
def get_claude_usage():
    data = _usage_store.get("total") or {
        "calls": 0, "input_tokens": 0, "output_tokens": 0, "objects": []
    }
    # 비용 추정 (claude-sonnet-4: input $3/1M, output $15/1M)
    cost_usd = (data["input_tokens"] * 3 + data["output_tokens"] * 15) / 1_000_000
    return {**data, "cost_usd": round(cost_usd, 4)}

@router.delete("/claude-usage")
def reset_claude_usage():
    _usage_store.set("total", {"calls":0,"input_tokens":0,"output_tokens":0,"objects":[]})
    return {"ok": True}

@router.delete("/claude-usage/objects")
def delete_claude_usage_objects(body: dict):
    """선택한 오브젝트 이력 삭제 — keys: [ts+name, ...]"""
    keys = set(body.get("keys", []))
    data = _usage_store.get("total") or {"calls":0,"input_tokens":0,"output_tokens":0,"objects":[]}
    data["objects"] = [o for o in data.get("objects",[]) if (o.get("ts","") + o.get("name","")) not in keys]
    _usage_store.set("total", data)
    return {"ok": True, "remaining": len(data["objects"])}


