# v9 패치 #18: 로그 백업 기능
# - 즉시 백업 (POST /settings/log-backup): 현재 로그를 gzip 으로 백업
# - 백업 목록 (GET  /settings/log-backups): 백업 파일 리스트
# - 백업 다운로드 (GET  /settings/log-backups/{name}): 파일 다운로드
# - 백업 삭제 (DELETE /settings/log-backups/{name}): 파일 삭제
# - 자동 스케줄 (cfg.log_backup_schedule): "off"|"hourly"|"6h"|"daily"
# ═══════════════════════════════════════════════════════════
from fastapi.responses import FileResponse
import gzip as _gzip
import threading as _thr

def _backup_dir() -> str:
    cfg = _cfg()
    d = cfg.get("log_backup_dir", "./logs/backups")
    d = os.path.abspath(d)
    os.makedirs(d, exist_ok=True)
    return d


def _do_backup_once(compress: bool = True) -> dict:
    """한 번 백업 수행 — backend/frontend 로그 각각 타임스탬프로 복사"""
    import shutil, time as _t
    cfg = _cfg()
    ts  = _t.strftime("%Y%m%d_%H%M%S")
    out_dir = _backup_dir()
    results = []
    for src_key, label in [("backend_log_file","backend"), ("frontend_log_file","frontend")]:
        src = cfg.get(src_key, f"./logs/databridge_{label}.log")
        src_abs = os.path.abspath(src)
        if not os.path.exists(src_abs):
            continue
        size = os.path.getsize(src_abs)
        if size == 0:
            continue
        base = os.path.basename(src_abs).replace(".log", f"_{ts}.log")
        if compress:
            out_path = os.path.join(out_dir, base + ".gz")
            try:
                with open(src_abs, "rb") as fi, _gzip.open(out_path, "wb", compresslevel=6) as fo:
                    shutil.copyfileobj(fi, fo, length=1024*1024)
                results.append({"source": label, "path": out_path,
                                "size": os.path.getsize(out_path),
                                "original_size": size, "compressed": True})
            except Exception as e:
                results.append({"source": label, "error": str(e)})
        else:
            out_path = os.path.join(out_dir, base)
            try:
                shutil.copy2(src_abs, out_path)
                results.append({"source": label, "path": out_path,
                                "size": os.path.getsize(out_path),
                                "original_size": size, "compressed": False})
            except Exception as e:
                results.append({"source": label, "error": str(e)})
    return {"ok": True, "ts": ts, "backups": results, "dir": out_dir}


def _purge_old_backups():
    """보관 기간 초과 백업 삭제 (cfg.log_backup_retention_days, 기본 30일)"""
    import time as _t
    cfg = _cfg()
    days = int(cfg.get("log_backup_retention_days", 30))
    if days <= 0:
        return 0
    cutoff = _t.time() - days * 86400
    d = _backup_dir()
    removed = 0
    for f in os.listdir(d):
        p = os.path.join(d, f)
        try:
            if os.path.isfile(p) and os.path.getmtime(p) < cutoff:
                os.remove(p)
                removed += 1
        except Exception:
            pass
    return removed


@router.post("/log-backup")
def log_backup_now(body: dict = None, _=Depends(require_operator)):
    """즉시 백업"""
    compress = True
    if body and "compress" in body:
        compress = bool(body["compress"])
    result = _do_backup_once(compress=compress)
    removed = _purge_old_backups()
    result["purged"] = removed
    return result


@router.get("/log-backups")
def list_log_backups(_=Depends(require_viewer)):
    """백업 파일 목록"""
    import time as _t
    d = _backup_dir()
    files = []
    try:
        for name in sorted(os.listdir(d), reverse=True):
            p = os.path.join(d, name)
            if not os.path.isfile(p):
                continue
            st = os.stat(p)
            files.append({
                "name": name,
                "size": st.st_size,
                "mtime": int(st.st_mtime),
                "mtime_str": _t.strftime("%Y-%m-%d %H:%M:%S", _t.localtime(st.st_mtime)),
                "compressed": name.endswith(".gz"),
            })
    except Exception as e:
        return {"files": [], "error": str(e), "dir": d}
    return {"files": files, "dir": d, "count": len(files)}


@router.get("/log-backups/{name}")
def download_log_backup(name: str, _=Depends(require_viewer)):
    """백업 파일 다운로드"""
    # 경로 탈출 방지
    if "/" in name or "\\" in name or ".." in name:
        raise HTTPException(400, "잘못된 파일명")
    d = _backup_dir()
    p = os.path.join(d, name)
    if not os.path.isfile(p):
        raise HTTPException(404, "파일을 찾을 수 없습니다")
    media = "application/gzip" if name.endswith(".gz") else "text/plain"
    return FileResponse(p, media_type=media, filename=name)


@router.delete("/log-backups/{name}")
def delete_log_backup(name: str, _=Depends(require_operator)):
    """백업 파일 삭제"""
    if "/" in name or "\\" in name or ".." in name:
        raise HTTPException(400, "잘못된 파일명")
    d = _backup_dir()
    p = os.path.join(d, name)
    if not os.path.isfile(p):
        raise HTTPException(404, "파일을 찾을 수 없습니다")
    try:
        os.remove(p)
        return {"ok": True, "removed": name}
    except Exception as e:
        return {"ok": False, "error": str(e)}


# ── 자동 백업 스케줄러 ───────────────────────────────────────
_backup_timer_stop = _thr.Event()
_backup_timer_thread: "_thr.Thread | None" = None
_backup_last_run: float = 0.0


def _scheduler_interval_sec() -> int:
    cfg = _cfg()
    s = str(cfg.get("log_backup_schedule", "off")).lower()
    # v95_p9_REAL: 옵션 확장 (5min, 30min, 2h, 12h 추가)
    return {
        "5min":   300,
        "30min":  1800,
        "hourly": 3600,
        "2h":     7200,
        "6h":     21600,
        "12h":    43200,
        "daily":  86400,
    }.get(s, 0)


def _current_log_size_mb() -> float:
    """v95_p9_REAL: 현재 백엔드 로그 파일 크기 (MB) - OR 조건 판단용"""
    cfg = _cfg()
    log_file = cfg.get("backend_log_file", "./logs/databridge_backend.log")
    abs_path = os.path.abspath(log_file)
    try:
        if os.path.exists(abs_path):
            return os.path.getsize(abs_path) / (1024 * 1024)
    except Exception:
        pass
    return 0.0


def _backup_scheduler_loop():
    """
    백그라운드 스레드 — 설정된 주기마다 _do_backup_once() 호출
    
    v95_p9_REAL: 본부장님 요청 본질 처방
    - 시간 도달 OR 사이즈 도달 (먼저 도달하는 쪽)
    - 시간 도달했어도 min_size_mb 미만이면 SKIP (작은 파일 양산 방지)
    - 사이즈 트리거가 설정되어 있고 도달하면 시간 안 기다리고 즉시 백업
    """
    global _backup_last_run
    import time as _t
    logger_bk = logging.getLogger("databridge.log_backup")
    while not _backup_timer_stop.wait(60):  # 1분마다 설정 확인
        try:
            cfg = _cfg()
            interval     = _scheduler_interval_sec()
            min_size_mb  = float(cfg.get("log_backup_min_size_mb", 1))
            trigger_mb   = float(cfg.get("log_backup_size_trigger_mb", 5))
            current_mb   = _current_log_size_mb()
            now          = _t.time()
            
            should_backup = False
            reason = ""
            
            # 조건 A: 사이즈 트리거 — 시간 무관 즉시
            if trigger_mb > 0 and current_mb >= trigger_mb:
                should_backup = True
                reason = f"사이즈 트리거 ({current_mb:.1f}MB ≥ {trigger_mb}MB)"
            # 조건 B: 시간 트리거 — 단, 최소 사이즈 조건 만족해야
            elif interval > 0 and (now - _backup_last_run) >= interval:
                if current_mb >= min_size_mb:
                    should_backup = True
                    reason = f"시간 트리거 (주기={interval}s, 크기={current_mb:.1f}MB ≥ 최소 {min_size_mb}MB)"
                else:
                    # 시간 도달했지만 크기 작음 → SKIP, 다음 사이클에 재평가
                    logger_bk.debug(
                        "시간 트리거 도달이지만 크기 부족 (%.1fMB < %.1fMB) — SKIP",
                        current_mb, min_size_mb
                    )
                    # last_run 은 갱신 X — 사이즈 채워지면 그때 백업
            
            if should_backup:
                logger_bk.info("자동 로그 백업 실행 — %s", reason)
                _do_backup_once(compress=True)
                _purge_old_backups()
                _backup_last_run = now
        except Exception as e:
            logger_bk.warning("자동 로그 백업 실패: %s", e)


def start_backup_scheduler():
    global _backup_timer_thread
    if _backup_timer_thread and _backup_timer_thread.is_alive():
        return
    _backup_timer_stop.clear()
    _backup_timer_thread = _thr.Thread(
        target=_backup_scheduler_loop,
        daemon=True,
        name="log-backup-scheduler"
    )
    _backup_timer_thread.start()


# 모듈 로드 시 스케줄러 시작 (설정이 off면 아무것도 안 함)
start_backup_scheduler()
