@router.get("/")
def get_settings(_=Depends(require_viewer)):
    cfg = _cfg()
    # API 키는 보안상 마스킹해서 반환 (프론트에서 표시용)
    # 실제 키가 있으면 앞10자+...+뒤4자로 마스킹
    key = cfg.get("anthropic_api_key", "")
    if key:
        cfg["anthropic_api_key_masked"] = key[:8] + "..." + key[-4:]
        cfg["anthropic_api_key_set"] = True
        cfg["anthropic_api_key_set_at"] = cfg.get("anthropic_api_key_set_at", "")
        cfg["anthropic_api_key"] = ""
    else:
        cfg["anthropic_api_key_masked"] = ""
        cfg["anthropic_api_key_set"] = False
        cfg["anthropic_api_key_set_at"] = ""
    return cfg


@router.put("/")
def update_settings(body: dict, request: Request, admin=Depends(require_admin)):
    from app.core import audit as _audit
    from app.core.audit import Actions as _Actions
    current = _store.get("config", {**_DEFAULTS})
    # API 키: 비어있거나 마스킹된 값(...)이 오면 기존 키 유지
    if "anthropic_api_key" in body:
        new_key = (body["anthropic_api_key"] or "").strip()
        if not new_key or "..." in new_key:
            body.pop("anthropic_api_key")  # 비거나 마스킹된 값 무시
        else:
            logging.info(f"[settings] API 키 저장: {new_key[:15]}...{new_key[-4:]} ({len(new_key)}자)")
            import datetime as _dt
            body["anthropic_api_key_set_at"] = _dt.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            # ── 디스크 저장 직전 암호화 ───────────────────────
            body["anthropic_api_key"] = _enc(new_key)
    # 내부 전용 키 제거
    for k in ["anthropic_api_key_masked", "anthropic_api_key_set"]:
        body.pop(k, None)
    current.update(body)
    _store.set("config", current)

    log_keys = {"log_level", "backend_log_file", "log_format", "log_max_mb", "log_backup_count"}
    if log_keys.intersection(body.keys()):
        _setup_logging(current)
        logging.info(f"로깅 설정 변경됨: { {k: body[k] for k in log_keys if k in body} }")
    # 응답에서도 암호문/평문 키 노출 방지
    resp = dict(current)
    resp["anthropic_api_key"] = ""
    # 감사 로그
    try:
        changed_keys = [k for k in body.keys() if k not in ("anthropic_api_key_masked","anthropic_api_key_set")]
        _audit.record(
            action=_Actions.SETTINGS_UPDATE, status="ok",
            user=admin, resource="settings", resource_id=None,
            ip=(request.client.host if request.client else None),
            details={"changed_keys": changed_keys},
        )
    except Exception:
        pass
    return resp


@router.get("/log-tail")
def tail_log(lines: int = 300, source: str = "backend", _=Depends(require_viewer)):
    """로그 파일 마지막 N줄 반환 (v9 패치 #17: 대용량 파일 대응)"""
    cfg = _cfg()
    key = "backend_log_file" if source == "backend" else "frontend_log_file"
    log_file = cfg.get(key, f"./logs/databridge_{source}.log")
    abs_path = os.path.abspath(log_file)
    # 안전 상한 (너무 크면 서버 메모리 부담)
    lines = max(1, min(int(lines), 200000))
    if not os.path.exists(abs_path):
        return {"lines": [], "file": abs_path, "exists": False,
                "message": f"로그 파일이 없습니다: {abs_path}"}
    try:
        # 파일 끝에서부터 역방향 청크 읽기 (전체 메모리 로드 방지)
        tail = _tail_read(abs_path, lines)
        # 총 줄수 대략 (정확치는 아니지만 사용자 참고용)
        total = _count_lines_fast(abs_path)
        return {
            "lines":  tail,
            "file":   abs_path,
            "exists": True,
            "total":  total,
            "source": source,
        }
    except Exception as e:
        return {"lines": [str(e)], "file": abs_path, "exists": True, "error": str(e)}


def _tail_read(path: str, n: int) -> list:
    """파일 끝에서부터 역방향으로 읽어 마지막 n줄 반환 (효율)"""
    CHUNK = 64 * 1024
    buf = b""
    lines_found = 0
    with open(path, "rb") as f:
        f.seek(0, 2)
        pos = f.tell()
        while pos > 0 and lines_found <= n:
            read = min(CHUNK, pos)
            pos -= read
            f.seek(pos)
            chunk = f.read(read)
            buf = chunk + buf
            lines_found = buf.count(b"\n")
    text = buf.decode("utf-8", errors="replace")
    arr = text.splitlines()
    if len(arr) > n:
        arr = arr[-n:]
    return arr


def _count_lines_fast(path: str) -> int:
    """줄 수 카운팅 (이진으로 \\n만 세서 빠름)"""
    try:
        count = 0
        with open(path, "rb") as f:
            while True:
                chunk = f.read(1024 * 1024)
                if not chunk:
                    break
                count += chunk.count(b"\n")
        return count
    except Exception:
        return 0


@router.get("/log-info")
def log_info(source: str = "backend", _=Depends(require_viewer)):
    """로그 파일 정보"""
    cfg = _cfg()
    key = "backend_log_file" if source == "backend" else "frontend_log_file"
    log_file = cfg.get(key, f"./logs/databridge_{source}.log")
    abs_path = os.path.abspath(log_file)
    exists   = os.path.exists(abs_path)
    size_kb  = round(os.path.getsize(abs_path) / 1024, 1) if exists else 0
    return {
        "file":    abs_path,
        "exists":  exists,
        "size_kb": size_kb,
        "level":   cfg.get("log_level", "INFO"),
        "source":  source,
    }


