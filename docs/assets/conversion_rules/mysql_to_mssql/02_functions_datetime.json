{
  "_meta": {
    "title": "MySQL → MSSQL 날짜/시간 함수 변환",
    "category": "FUNCTION_DATETIME",
    "src_db": "mysql",
    "tgt_db": "mssql",
    "version": "1.0",
    "description": "MySQL 날짜/시간 함수 → SQL Server 동등 함수"
  },
  "rules": [
    {
      "id": "fn_now",
      "src": "NOW()",
      "tgt": "GETDATE()",
      "note": "현재 날짜+시간",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_sysdate",
      "src": "SYSDATE()",
      "tgt": "GETDATE()",
      "note": "함수 실행 시점 시간 → GETDATE()",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_current_timestamp",
      "src": "CURRENT_TIMESTAMP",
      "tgt": "GETDATE()",
      "note": "CURRENT_TIMESTAMP → GETDATE()",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_curdate",
      "src": "CURDATE()",
      "tgt": "CAST(GETDATE() AS DATE)",
      "note": "현재 날짜만",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_current_date",
      "src": "CURRENT_DATE()",
      "tgt": "CAST(GETDATE() AS DATE)",
      "note": "CURRENT_DATE → CAST DATE",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_current_date2",
      "src": "CURRENT_DATE",
      "tgt": "CAST(GETDATE() AS DATE)",
      "note": "CURRENT_DATE → CAST DATE",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_curtime",
      "src": "CURTIME()",
      "tgt": "CAST(GETDATE() AS TIME)",
      "note": "현재 시간만",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_utc_timestamp",
      "src": "UTC_TIMESTAMP()",
      "tgt": "GETUTCDATE()",
      "note": "UTC 현재시간",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_utc_date",
      "src": "UTC_DATE()",
      "tgt": "CAST(GETUTCDATE() AS DATE)",
      "note": "UTC 날짜",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_add_year",
      "src": "DATE_ADD\\s*\\(\\s*([^,]+)\\s*,\\s*INTERVAL\\s+([^\\s]+)\\s+YEAR\\s*\\)",
      "tgt": "DATEADD(year, \\2, \\1)",
      "regex": true,
      "note": "DATE_ADD YEAR → DATEADD",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_add_month",
      "src": "DATE_ADD\\s*\\(\\s*([^,]+)\\s*,\\s*INTERVAL\\s+([^\\s]+)\\s+MONTH\\s*\\)",
      "tgt": "DATEADD(month, \\2, \\1)",
      "regex": true,
      "note": "DATE_ADD MONTH → DATEADD",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_add_day",
      "src": "DATE_ADD\\s*\\(\\s*([^,]+)\\s*,\\s*INTERVAL\\s+([^\\s]+)\\s+DAY\\s*\\)",
      "tgt": "DATEADD(day, \\2, \\1)",
      "regex": true,
      "note": "DATE_ADD DAY → DATEADD",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_add_hour",
      "src": "DATE_ADD\\s*\\(\\s*([^,]+)\\s*,\\s*INTERVAL\\s+([^\\s]+)\\s+HOUR\\s*\\)",
      "tgt": "DATEADD(hour, \\2, \\1)",
      "regex": true,
      "note": "DATE_ADD HOUR → DATEADD",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_add_minute",
      "src": "DATE_ADD\\s*\\(\\s*([^,]+)\\s*,\\s*INTERVAL\\s+([^\\s]+)\\s+MINUTE\\s*\\)",
      "tgt": "DATEADD(minute, \\2, \\1)",
      "regex": true,
      "note": "DATE_ADD MINUTE → DATEADD",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_add_second",
      "src": "DATE_ADD\\s*\\(\\s*([^,]+)\\s*,\\s*INTERVAL\\s+([^\\s]+)\\s+SECOND\\s*\\)",
      "tgt": "DATEADD(second, \\2, \\1)",
      "regex": true,
      "note": "DATE_ADD SECOND → DATEADD",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_add_week",
      "src": "DATE_ADD\\s*\\(\\s*([^,]+)\\s*,\\s*INTERVAL\\s+([^\\s]+)\\s+WEEK\\s*\\)",
      "tgt": "DATEADD(week, \\2, \\1)",
      "regex": true,
      "note": "DATE_ADD WEEK → DATEADD",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_sub_year",
      "src": "DATE_SUB\\s*\\(\\s*([^,]+)\\s*,\\s*INTERVAL\\s+([^\\s]+)\\s+YEAR\\s*\\)",
      "tgt": "DATEADD(year, -\\2, \\1)",
      "regex": true,
      "note": "DATE_SUB YEAR → DATEADD 음수",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_sub_month",
      "src": "DATE_SUB\\s*\\(\\s*([^,]+)\\s*,\\s*INTERVAL\\s+([^\\s]+)\\s+MONTH\\s*\\)",
      "tgt": "DATEADD(month, -\\2, \\1)",
      "regex": true,
      "note": "DATE_SUB MONTH → DATEADD 음수",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_sub_day",
      "src": "DATE_SUB\\s*\\(\\s*([^,]+)\\s*,\\s*INTERVAL\\s+([^\\s]+)\\s+DAY\\s*\\)",
      "tgt": "DATEADD(day, -\\2, \\1)",
      "regex": true,
      "note": "DATE_SUB DAY → DATEADD 음수",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_year",
      "src": "YEAR\\(",
      "tgt": "YEAR(",
      "note": "YEAR() OK",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_month",
      "src": "MONTH\\(",
      "tgt": "MONTH(",
      "note": "MONTH() OK",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_day",
      "src": "DAY\\(",
      "tgt": "DAY(",
      "note": "DAY() OK",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_hour",
      "src": "HOUR\\s*\\(([^)]+)\\)",
      "tgt": "DATEPART(hour, \\1)",
      "regex": true,
      "note": "HOUR() → DATEPART(hour)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_minute_fn",
      "src": "MINUTE\\s*\\(([^)]+)\\)",
      "tgt": "DATEPART(minute, \\1)",
      "regex": true,
      "note": "MINUTE() → DATEPART(minute)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_second",
      "src": "SECOND\\s*\\(([^)]+)\\)",
      "tgt": "DATEPART(second, \\1)",
      "regex": true,
      "note": "SECOND() → DATEPART(second)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_quarter",
      "src": "QUARTER\\s*\\(([^)]+)\\)",
      "tgt": "DATEPART(quarter, \\1)",
      "regex": true,
      "note": "QUARTER() → DATEPART(quarter)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_week",
      "src": "WEEK\\s*\\(([^)]+)\\)",
      "tgt": "DATEPART(week, \\1)",
      "regex": true,
      "note": "WEEK() → DATEPART(week)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_dayofweek",
      "src": "DAYOFWEEK\\s*\\(([^)]+)\\)",
      "tgt": "DATEPART(weekday, \\1)",
      "regex": true,
      "note": "DAYOFWEEK() → DATEPART(weekday)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_dayofyear",
      "src": "DAYOFYEAR\\s*\\(([^)]+)\\)",
      "tgt": "DATEPART(dayofyear, \\1)",
      "regex": true,
      "note": "DAYOFYEAR() → DATEPART(dayofyear)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_monthname",
      "src": "MONTHNAME\\s*\\(([^)]+)\\)",
      "tgt": "DATENAME(month, \\1)",
      "regex": true,
      "note": "MONTHNAME() → DATENAME(month)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_dayname",
      "src": "DAYNAME\\s*\\(([^)]+)\\)",
      "tgt": "DATENAME(weekday, \\1)",
      "regex": true,
      "note": "DAYNAME() → DATENAME(weekday)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_last_day",
      "src": "LAST_DAY\\s*\\(([^)]+)\\)",
      "tgt": "EOMONTH(\\1)",
      "regex": true,
      "note": "LAST_DAY → EOMONTH",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_fn",
      "src": "DATE\\s*\\(([^)]+)\\)",
      "tgt": "CAST(\\1 AS DATE)",
      "regex": true,
      "note": "DATE() → CAST AS DATE",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_str_to_date_ymd",
      "src": "STR_TO_DATE\\(([^,]+),\\s*'%Y-%m-%d'\\)",
      "tgt": "CONVERT(DATE, \\1, 120)",
      "regex": true,
      "note": "STR_TO_DATE → CONVERT",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_str_to_date_generic",
      "src": "STR_TO_DATE\\(",
      "tgt": "CONVERT(DATE, ",
      "note": "STR_TO_DATE → CONVERT(DATE)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_format_ym",
      "src": "DATE_FORMAT\\s*\\(([^,]+),\\s*'%Y-%m'\\s*\\)",
      "tgt": "FORMAT(\\1, 'yyyy-MM')",
      "regex": true,
      "note": "DATE_FORMAT %Y-%m → FORMAT yyyy-MM",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_format_ymd",
      "src": "DATE_FORMAT\\s*\\(([^,]+),\\s*'%Y-%m-%d'\\s*\\)",
      "tgt": "CONVERT(VARCHAR(10), \\1, 120)",
      "regex": true,
      "note": "DATE_FORMAT %Y-%m-%d → CONVERT(120)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_format_ymd_hms",
      "src": "DATE_FORMAT\\s*\\(([^,]+),\\s*'%Y-%m-%d %H:%i:%s'\\s*\\)",
      "tgt": "CONVERT(VARCHAR(19), \\1, 120)",
      "regex": true,
      "note": "DATE_FORMAT 전체 → CONVERT(120)",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_format_Ym",
      "src": "DATE_FORMAT\\s*\\(([^,]+),\\s*'%Y%m'\\s*\\)",
      "tgt": "FORMAT(\\1, 'yyyyMM')",
      "regex": true,
      "note": "DATE_FORMAT %Y%m → FORMAT yyyyMM",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_date_format_generic",
      "src": "DATE_FORMAT\\(",
      "tgt": "FORMAT(",
      "note": "DATE_FORMAT → FORMAT (포맷 문자열 수동 변환 필요)",
      "warning": true,
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_makedate",
      "src": "MAKEDATE\\(([^,]+),\\s*([^)]+)\\)",
      "tgt": "DATEFROMPARTS(\\1, 1, \\2)",
      "regex": true,
      "note": "MAKEDATE(year, dayofyear) → DATEFROMPARTS 근사",
      "warning": true,
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_convert_tz",
      "src": "CONVERT_TZ\\(([^,]+),\\s*([^,]+),\\s*([^)]+)\\)",
      "tgt": "TODATETIMEOFFSET(\\1, \\3)",
      "regex": true,
      "note": "CONVERT_TZ → TODATETIMEOFFSET (근사)",
      "warning": true,
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_period_diff",
      "src": "PERIOD_DIFF\\(([^,]+),\\s*([^)]+)\\)",
      "tgt": "DATEDIFF(month, CAST(\\2 AS DATE), CAST(\\1 AS DATE))",
      "regex": true,
      "note": "PERIOD_DIFF → DATEDIFF month 근사",
      "warning": true,
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_adddate",
      "src": "ADDDATE\\(([^,]+),\\s*([^)]+)\\)",
      "tgt": "DATEADD(day, \\2, \\1)",
      "regex": true,
      "note": "ADDDATE → DATEADD day",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_subdate",
      "src": "SUBDATE\\(([^,]+),\\s*([^)]+)\\)",
      "tgt": "DATEADD(day, -\\2, \\1)",
      "regex": true,
      "note": "SUBDATE → DATEADD 음수",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_timestampadd",
      "src": "TIMESTAMPADD\\(([^,]+),\\s*([^,]+),\\s*([^)]+)\\)",
      "tgt": "DATEADD(\\1, \\2, \\3)",
      "regex": true,
      "note": "TIMESTAMPADD → DATEADD",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_from_unixtime",
      "src": "FROM_UNIXTIME\\(([^)]+)\\)",
      "tgt": "DATEADD(second, \\1, '1970-01-01')",
      "regex": true,
      "note": "FROM_UNIXTIME → DATEADD from epoch",
      "category": "FUNCTION_DATETIME"
    },
    {
      "id": "fn_unix_timestamp",
      "src": "UNIX_TIMESTAMP\\(([^)]+)\\)",
      "tgt": "DATEDIFF(second, '1970-01-01', \\1)",
      "regex": true,
      "note": "UNIX_TIMESTAMP → DATEDIFF from epoch",
      "category": "FUNCTION_DATETIME"
    }
  ]
}